---
interface Props {
  title: string;
  active: string;
}
const { title, active } = Astro.props;

const nav = [
  { href: '/admin',             label: 'Obras',        key: 'obras',        icon: '<rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>' },
  { href: '/admin/pedidos',     label: 'Pedidos',      key: 'pedidos',      icon: '<path d="M6 2 4 6H2v14h20V6h-2L18 2H6z"/><path d="M12 11v6"/><path d="M9 14h6"/>' },
  { href: '/admin/contactos',   label: 'Contactos',    key: 'contactos',    icon: '<circle cx="9" cy="7" r="4"/><path d="M3 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/><path d="M21 21v-2a4 4 0 0 0-3-3.87"/>' },
  { href: '/admin/descuentos',  label: 'Descuentos',   key: 'descuentos',   icon: '<path d="M12 2 2 7l10 5 10-5-10-5z"/><path d="m2 17 10 5 10-5"/><path d="m2 12 10 5 10-5"/>' },
  { href: '/admin/cotizaciones',label: 'Cotizaciones', key: 'cotizaciones', icon: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>' },
];
---
<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>{title} — Luma Arte Admin</title>
  <meta name="robots" content="noindex" />
  <style>
    @font-face{font-family:'Mackinac';src:url('/fonts/Mackinac-Book.otf') format('opentype');font-weight:400;font-style:normal}
    @font-face{font-family:'Mackinac';src:url('/fonts/Mackinac-BookItalic.otf') format('opentype');font-weight:400;font-style:italic}
    @font-face{font-family:'CoFo Sans';src:url('/fonts/CoFoSans-Regular.otf') format('opentype');font-weight:400}
    @font-face{font-family:'CoFo Sans';src:url('/fonts/CoFoSans-Light.otf') format('opentype');font-weight:300}
    *{box-sizing:border-box;margin:0;padding:0}
    html,body{height:100%}
    body{font-family:'CoFo Sans',system-ui,sans-serif;background:#f3f0e9;color:#211f18;display:flex;min-height:100vh}

    /* SIDEBAR */
    .sidebar{width:220px;min-height:100vh;background:#1a1c12;display:flex;flex-direction:column;position:fixed;top:0;left:0;z-index:20}
    .sidebar-brand{padding:28px 24px 20px;border-bottom:.5px solid rgba(253,252,248,.08)}
    .brand-name{font-family:'Mackinac',serif;font-size:20px;color:#fdfcf8;letter-spacing:-.01em;text-decoration:none;display:block}
    .brand-name em{font-style:italic}
    .brand-sub{font-size:10px;color:rgba(253,252,248,.35);letter-spacing:.12em;text-transform:uppercase;margin-top:4px}

    .sidebar-nav{flex:1;padding:16px 12px}
    .nav-item{display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:8px;color:rgba(253,252,248,.45);text-decoration:none;font-size:13px;transition:all .15s;margin-bottom:2px;cursor:pointer}
    .nav-item svg{width:16px;height:16px;flex-shrink:0;stroke:currentColor;fill:none;stroke-width:1.75;stroke-linecap:round;stroke-linejoin:round}
    .nav-item:hover{background:rgba(253,252,248,.06);color:rgba(253,252,248,.8)}
    .nav-item.active{background:rgba(84,88,47,.4);color:#c8cc8a}
    .nav-item.soon{opacity:.45;cursor:default}
    .soon-tag{font-size:9px;letter-spacing:.06em;background:rgba(253,252,248,.1);color:rgba(253,252,248,.4);padding:2px 6px;border-radius:4px;margin-left:auto}

    .sidebar-footer{padding:16px 12px;border-top:.5px solid rgba(253,252,248,.08)}
    .sidebar-ext{display:flex;align-items:center;gap:10px;padding:8px 12px;border-radius:8px;color:rgba(253,252,248,.35);text-decoration:none;font-size:12px;margin-bottom:4px}
    .sidebar-ext:hover{color:rgba(253,252,248,.6)}
    .sidebar-ext svg{width:14px;height:14px;stroke:currentColor;fill:none;stroke-width:1.75;stroke-linecap:round;stroke-linejoin:round;flex-shrink:0}
    .logout-form{width:100%}
    .logout-btn{width:100%;display:flex;align-items:center;gap:10px;padding:8px 12px;border-radius:8px;background:none;border:none;color:rgba(253,252,248,.35);font-size:12px;cursor:pointer;font-family:inherit;text-align:left}
    .logout-btn:hover{color:#fdfcf8;background:rgba(253,252,248,.06)}
    .logout-btn svg{width:14px;height:14px;stroke:currentColor;fill:none;stroke-width:1.75;stroke-linecap:round;stroke-linejoin:round;flex-shrink:0}

    /* TOPBAR MÓVIL */
    .mobile-bar{display:none;background:#1a1c12;height:52px;align-items:center;justify-content:space-between;padding:0 20px;position:sticky;top:0;z-index:20}
    .mobile-brand{font-family:'Mackinac',serif;font-size:17px;color:#fdfcf8}
    .mobile-brand em{font-style:italic}
    .hamburger{background:none;border:none;color:rgba(253,252,248,.7);cursor:pointer;padding:6px}
    .hamburger svg{width:20px;height:20px;stroke:currentColor;fill:none;stroke-width:1.75;stroke-linecap:round}

    /* MAIN */
    .main-wrap{margin-left:220px;flex:1;min-height:100vh;display:flex;flex-direction:column}
    .main-content{flex:1;padding:36px 32px;max-width:1100px;width:100%}

    /* OVERLAY MÓVIL */
    .sidebar-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:19}

    @media(max-width:768px){
      .sidebar{transform:translateX(-100%);transition:transform .25s ease}
      .sidebar.open{transform:translateX(0)}
      .sidebar-overlay.open{display:block}
      .mobile-bar{display:flex}
      .main-wrap{margin-left:0}
      .main-content{padding:24px 16px}
    }
  </style>
</head>
<body>

  <!-- SIDEBAR -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-brand">
      <a class="brand-name" href="/admin">Luma <em>Arte</em></a>
      <div class="brand-sub">Panel de gestión</div>
    </div>

    <nav class="sidebar-nav">
      {nav.map(item => (
        <a class={`nav-item${active === item.key ? ' active' : ''}`} href={item.href}>
          <svg viewBox="0 0 24 24" set:html={item.icon} />
          {item.label}
        </a>
      ))}
    </nav>

    <div class="sidebar-footer">
      <a class="sidebar-ext" href="/" target="_blank">
        <svg viewBox="0 0 24 24"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        Ver sitio web
      </a>
      <form class="logout-form" method="POST" action="/api/admin/logout">
        <button class="logout-btn" type="submit">
          <svg viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
          Cerrar sesión
        </button>
      </form>
    </div>
  </aside>

  <div class="sidebar-overlay" id="overlay" onclick="closeSidebar()"></div>

  <!-- CONTENIDO -->
  <div class="main-wrap">
    <div class="mobile-bar">
      <span class="mobile-brand">Luma <em>Arte</em></span>
      <button class="hamburger" onclick="openSidebar()">
        <svg viewBox="0 0 24 24"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>
    <div class="main-content">
      <slot />
    </div>
  </div>

  <script>
    function openSidebar(){
      document.getElementById('sidebar').classList.add('open');
      document.getElementById('overlay').classList.add('open');
    }
    function closeSidebar(){
      document.getElementById('sidebar').classList.remove('open');
      document.getElementById('overlay').classList.remove('open');
    }
    window.openSidebar = openSidebar;
    window.closeSidebar = closeSidebar;
  </script>
</body>
</html>
