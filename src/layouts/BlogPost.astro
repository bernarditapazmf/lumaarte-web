---
import type { CollectionEntry } from 'astro:content';
import CartDrawer from '../components/CartDrawer.astro';
type Props = CollectionEntry<'blog'>['data'];
const { title, description, pubDate, heroImage } = Astro.props;
const fecha = pubDate.toLocaleDateString('es-CL', { day: 'numeric', month: 'long', year: 'numeric' });
---
<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />

<!-- Google Analytics 4 -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-VZNFX2FCYJ"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-VZNFX2FCYJ');
</script>

<title>{title} — Luma Arte</title>
<meta name="description" content={description} />
<link rel="canonical" href={`https://www.lumaarte.com/blog/${Astro.url?.pathname?.split('/').filter(Boolean).pop() || ''}`} />
<meta name="robots" content="index, follow" />
<meta property="og:type" content="article" />
<meta property="og:locale" content="es_CL" />
<meta property="og:site_name" content="Luma Arte" />
<meta property="og:title" content={`${title} — Luma Arte`} />
<meta property="og:description" content={description} />
{heroImage && <meta property="og:image" content={`https://www.lumaarte.com${heroImage}`} />}
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Spline+Sans+Mono:wght@400;500&display=swap" rel="stylesheet" />

<style is:global>
@font-face{font-family:'Mackinac';src:url('/fonts/Mackinac-Book.otf') format('opentype');font-weight:400;font-style:normal;font-display:swap}
@font-face{font-family:'Mackinac';src:url('/fonts/Mackinac-BookItalic.otf') format('opentype');font-weight:400;font-style:italic;font-display:swap}
@font-face{font-family:'Mackinac';src:url('/fonts/Mackinac-Medium.otf') format('opentype');font-weight:500;font-style:normal;font-display:swap}
@font-face{font-family:'Mackinac';src:url('/fonts/Mackinac-MediumItalic.otf') format('opentype');font-weight:500;font-style:italic;font-display:swap}
@font-face{font-family:'CoFo Sans';src:url('/fonts/CoFoSans-Light.otf') format('opentype');font-weight:300;font-style:normal;font-display:swap}
@font-face{font-family:'CoFo Sans';src:url('/fonts/CoFoSans-Regular.otf') format('opentype');font-weight:400;font-style:normal;font-display:swap}
@font-face{font-family:'CoFo Sans';src:url('/fonts/CoFoSans-Italic.otf') format('opentype');font-weight:400;font-style:italic;font-display:swap}
@font-face{font-family:'CoFo Sans';src:url('/fonts/CoFoSans-Medium.otf') format('opentype');font-weight:500;font-style:normal;font-display:swap}

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;overflow-x:hidden}
body{background:#FDFCF8;font-family:'CoFo Sans',system-ui,sans-serif;color:#211f18;-webkit-font-smoothing:antialiased}
img{display:block;max-width:100%}
a{color:#54582f}
a:hover{color:#3c3f21}

@keyframes lumaDrift{0%{transform:scale(1.08) translate(0,0)}50%{transform:scale(1.14) translate(-1%,-.8%)}100%{transform:scale(1.08) translate(0,0)}}
@media(prefers-reduced-motion:reduce){*{animation:none!important}}

/* NAV */
.nav{position:absolute;top:0;left:0;right:0;display:flex;align-items:center;justify-content:space-between;padding:26px 48px;z-index:20}
.nav-logo{height:60px;width:104px;filter:brightness(0) invert(1);opacity:.97;object-fit:contain}
.nav-links{display:flex;align-items:center;gap:36px}
.nav-link{font:500 12px/1 'Spline Sans Mono',monospace;letter-spacing:.16em;text-transform:uppercase;color:#fdfcf8;text-decoration:none;padding-bottom:3px;border-bottom:1px solid transparent;transition:border-color .2s}
.nav-link:hover{border-bottom-color:rgba(253,252,248,.7)}
.nav-link--active{border-bottom-color:rgba(253,252,248,.8)}
.nav-cart{display:flex;align-items:center;gap:8px;background:none;border:none;color:#fdfcf8;padding:6px 2px;font:500 11px/1 'Spline Sans Mono',monospace;letter-spacing:.06em;cursor:pointer}
.nav-cart:hover{opacity:.8}

/* HERO */
.hero{position:relative;height:62vh;min-height:440px;overflow:hidden;background:#1a1f14}
.hero-bg{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 38%;animation:lumaDrift 52s ease-in-out infinite}
.hero-overlay{position:absolute;inset:0;background:linear-gradient(180deg,rgba(20,22,14,.52) 0%,rgba(20,22,14,.1) 30%,rgba(20,22,14,.28) 58%,rgba(20,22,14,.82) 100%)}
.hero-body{position:absolute;left:48px;right:48px;bottom:64px;z-index:10;max-width:860px}
.hero-eyebrow{font:500 11px/1 'Spline Sans Mono',monospace;letter-spacing:.3em;text-transform:uppercase;color:rgba(253,252,248,.7);margin-bottom:18px}
.hero-h1{font-family:'Mackinac',serif;font-weight:400;font-size:clamp(32px,4.5vw,56px);line-height:1.1;letter-spacing:-.02em;color:#fdfcf8}
.hero-date{margin-top:16px;font:500 11px/1 'Spline Sans Mono',monospace;letter-spacing:.2em;text-transform:uppercase;color:rgba(253,252,248,.55)}

/* PROSE */
.prose-wrap{background:#FDFCF8;padding:80px 48px 104px}
.prose{max-width:680px;margin:0 auto}

.prose p{font:300 17px/1.82 'CoFo Sans';color:rgba(33,31,24,.88);margin-bottom:22px}
.prose p:last-child{margin-bottom:0}
.prose h2{font-family:'Mackinac',serif;font-weight:400;font-size:clamp(24px,3vw,34px);line-height:1.18;letter-spacing:-.015em;color:#211f18;margin:52px 0 18px}
.prose h3{font-family:'Mackinac',serif;font-weight:400;font-style:italic;font-size:clamp(20px,2.5vw,26px);line-height:1.25;letter-spacing:-.01em;color:#211f18;margin:36px 0 14px}
.prose strong{font-weight:500;color:#211f18}
.prose em{font-style:italic}
.prose a{color:#54582f;text-decoration:underline;text-underline-offset:3px}
.prose a:hover{color:#3c3f21}
.prose hr{border:none;border-top:.5px solid rgba(33,31,24,.2);margin:44px 0}
.prose ul,.prose ol{padding-left:24px;margin-bottom:22px}
.prose li{font:300 17px/1.75 'CoFo Sans';color:rgba(33,31,24,.88);margin-bottom:6px}
.prose blockquote{border-left:2px solid #54582f;padding:4px 0 4px 22px;margin:28px 0}
.prose blockquote p{font-family:'Mackinac',serif;font-weight:400;font-style:italic;font-size:20px;line-height:1.5;color:#211f18;margin:0}

/* Tablas */
.prose table{width:100%;border-collapse:collapse;margin:28px 0;font:300 15px/1.5 'CoFo Sans'}
.prose th{font:500 11px/1 'Spline Sans Mono',monospace;letter-spacing:.14em;text-transform:uppercase;color:rgba(33,31,24,.55);padding:10px 14px;border-bottom:.5px solid rgba(33,31,24,.25);text-align:left}
.prose td{padding:10px 14px;border-bottom:.5px solid rgba(33,31,24,.1);color:rgba(33,31,24,.85)}

/* VOLVER + FOOTER */
.back-bar{background:#FDFCF8;padding:0 48px 52px}
.back-link{display:inline-flex;align-items:center;gap:8px;font:500 11px/1 'Spline Sans Mono',monospace;letter-spacing:.14em;text-transform:uppercase;color:rgba(33,31,24,.45);text-decoration:none;transition:color .2s}
.back-link:hover{color:#54582f}

.footer{background:#211f18;color:#f3f0e9;padding:64px 48px 38px}
.footer-inner{max-width:1000px;margin:0 auto}
.footer-top{display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:36px;padding-bottom:42px;border-bottom:.5px solid rgba(243,240,233,.18)}
.footer-logo{height:52px;filter:brightness(0) invert(1);opacity:.95}
.footer-tagline{margin:22px 0 0;font:300 14px/1.7 'CoFo Sans';color:rgba(243,240,233,.65)}
.footer-col-label{font:500 11px/1 'Spline Sans Mono',monospace;letter-spacing:.22em;text-transform:uppercase;color:rgba(243,240,233,.5);margin-bottom:14px}
.footer-email{display:block;color:#f3f0e9;font:400 14px 'CoFo Sans';text-decoration:none;margin-bottom:8px}
.footer-email:hover{color:#cdd3ae}
.footer-address{font:300 13px/1.7 'CoFo Sans';color:rgba(243,240,233,.55)}
.footer-ig{display:inline-flex;align-items:center;gap:10px;color:#f3f0e9;text-decoration:none;font:400 15px 'CoFo Sans'}
.footer-ig:hover{color:#cdd3ae}
.footer-copy{padding-top:22px;font:400 11.5px/1 'CoFo Sans';color:rgba(243,240,233,.45)}
.footer-links{display:flex;gap:52px}

/* RESPONSIVE */
@media(max-width:900px){
  .nav{padding:20px 24px}
  .nav-links{gap:20px}
  .nav-link{font-size:10px}
  .hero-body{left:24px;right:24px;bottom:40px}
  .prose-wrap{padding:52px 24px 72px}
  .back-bar{padding:0 24px 40px}
  .footer{padding:48px 24px 32px}
  .footer-top{flex-direction:column}
  .footer-links{gap:32px}
}
@media(max-width:600px){
  .nav-links{display:none}
  .nav-logo{height:50px;width:87px}
  .hero-h1{font-size:28px}
  .prose p,.prose li{font-size:16px}
  .prose h2{font-size:22px}
  .prose h3{font-size:18px}
}
</style>
</head>
<body>

<!-- HERO -->
<article>
<header class="hero" aria-label={title}>
  {heroImage
    ? <img class="hero-bg" src={heroImage} alt={title} fetchpriority="high" decoding="async" />
    : <div class="hero-bg" style="background:#1a1f14"></div>
  }
  <div class="hero-overlay" aria-hidden="true"></div>
  <nav class="nav" aria-label="Navegación principal">
    <a href="/" aria-label="Ir al inicio — Luma Arte">
      <img class="nav-logo" src="/img/luma-logo.png" alt="Luma Arte" />
    </a>
    <div class="nav-links">
      <a class="nav-link" href="/#pinturas">Pinturas</a>
      <a class="nav-link" href="/sobremi">Sobre mí</a>
      <a class="nav-link nav-link--active" href="/blog">Blog</a>
      <a class="nav-link" href="/#giftcards">Giftcard</a>
      <a class="nav-link" href="/#contacto">Contacto</a>
      <button class="nav-cart" id="btn-cart-shared" aria-label="Ver carrito">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        <span id="cart-count-shared">(0)</span>
      </button>
    </div>
  </nav>
  <div class="hero-body">
    <p class="hero-eyebrow">Luma Arte · Blog</p>
    <h1 class="hero-h1">{title}</h1>
    <p class="hero-date">{fecha}</p>
  </div>
</header>

<!-- CONTENIDO -->
<div class="prose-wrap">
  <div class="prose">
    <slot />
  </div>
</div>

<div class="back-bar">
  <a class="back-link" href="/blog">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M19 12H5"/><path d="m12 5-7 7 7 7"/></svg>
    Volver al blog
  </a>
</div>
</article>

<!-- FOOTER -->
<footer class="footer">
  <div class="footer-inner">
    <div class="footer-top">
      <div>
        <img class="footer-logo" src="/img/luma-logo.png" alt="Luma Arte" />
        <p class="footer-tagline">Arte original inspirado en la naturaleza del sur de Chile.</p>
      </div>
      <div class="footer-links">
        <div>
          <div class="footer-col-label">Contacto</div>
          <a class="footer-email" href="mailto:contacto@lumaproducciones.cl">contacto@lumaproducciones.cl</a>
          <div class="footer-address">Puerto Varas, Región de Los Lagos</div>
        </div>
        <div>
          <div class="footer-col-label">Síguenos</div>
          <a class="footer-ig" href="https://www.instagram.com/lumaartechile" target="_blank" rel="noopener">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5.5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
            @lumaartechile
          </a>
        </div>
      </div>
    </div>
    <div class="footer-copy">© 2026 Luma Producciones · Todas las obras son originales de Luma.</div>
  </div>
</footer>

<CartDrawer />
</body>
</html>
