---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { isAuthenticated } from '../../lib/auth.js';
import { initDb } from '../../lib/db.js';

if (!isAuthenticated(Astro.request)) return Astro.redirect('/admin/login');

const db = await initDb();
const { rows: pedidos } = await db.execute('SELECT * FROM pedidos ORDER BY created_at DESC');
const totalVentas = pedidos.reduce((s, p) => s + (Number(p.monto) || 0), 0);
const pendientesEnvio = pedidos.filter(p => ['pagado','en_enmarcado'].includes(p.estado)).length;
---
<AdminLayout title="Pedidos" active="pedidos">
  <style>
    h1{font-family:'Mackinac',serif;font-size:26px;font-weight:400;margin-bottom:28px}
    h1 em{font-style:italic}
    .stats{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:28px}
    .stat{background:#fdfcf8;border:.5px solid rgba(33,31,24,.1);border-radius:10px;padding:18px 20px}
    .stat-num{font-family:'Mackinac',serif;font-size:28px;font-weight:400;line-height:1;margin-bottom:4px}
    .stat-label{font-size:10px;color:rgba(33,31,24,.45);letter-spacing:.06em;text-transform:uppercase}
    .section-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
    .btn-new{display:inline-flex;align-items:center;gap:6px;background:#54582f;color:#fdfcf8;text-decoration:none;padding:9px 18px;border-radius:8px;font-size:12px;letter-spacing:.04em}
    .btn-new:hover{background:#3a3d1f}
    .table-wrap{background:#fdfcf8;border:.5px solid rgba(33,31,24,.1);border-radius:10px;overflow:hidden}
    table{width:100%;border-collapse:collapse}
    th{text-align:left;padding:10px 16px;font-size:10px;letter-spacing:.08em;color:rgba(33,31,24,.4);border-bottom:.5px solid rgba(33,31,24,.08);font-weight:400;text-transform:uppercase}
    td{padding:12px 16px;border-bottom:.5px solid rgba(33,31,24,.06);font-size:13px;vertical-align:middle}
    tr:last-child td{border-bottom:none}
    tr:hover td{background:#faf9f5}
    .empty{text-align:center;padding:60px 20px;color:rgba(33,31,24,.4);font-size:13px}
    select.estado-sel{padding:4px 8px;border:.5px solid rgba(33,31,24,.2);border-radius:5px;font-size:11px;font-family:inherit;background:#fff;cursor:pointer}
    @media(max-width:700px){
      .stats{grid-template-columns:1fr 1fr}
      th:nth-child(5),td:nth-child(5),th:nth-child(6),td:nth-child(6){display:none}
    }
  </style>

  <div class="stats">
    <div class="stat">
      <div class="stat-num">{pedidos.length}</div>
      <div class="stat-label">Total pedidos</div>
    </div>
    <div class="stat">
      <div class="stat-num">${totalVentas.toLocaleString('es-CL')}</div>
      <div class="stat-label">Total vendido</div>
    </div>
    <div class="stat">
      <div class="stat-num">{pendientesEnvio}</div>
      <div class="stat-label">Pendientes envío</div>
    </div>
  </div>

  <div class="section-header">
    <h1>Pedidos <em>y ventas</em></h1>
    <a class="btn-new" href="/admin/pedidos/nuevo">+ Registrar pedido</a>
  </div>

  <div class="table-wrap">
    {pedidos.length === 0 ? (
      <div class="empty">Aún no hay pedidos. Los pagos de Flow aparecerán aquí automáticamente.</div>
    ) : (
      <table>
        <thead>
          <tr>
            <th>Cliente</th><th>Obra · Talla</th><th>Monto</th><th>Estado</th><th>F. pedido</th><th>F. entrega est.</th>
          </tr>
        </thead>
        <tbody>
          {pedidos.map(p => (
            <tr>
              <td>
                <strong>{p.cliente_nombre || '—'}</strong>
                <div style="font-size:11px;color:rgba(33,31,24,.4)">{p.cliente_email}</div>
              </td>
              <td>
                {p.obra_nombre || '—'}
                {p.talla && <div style="font-size:11px;color:rgba(33,31,24,.4)">{p.talla} · {p.mat === 'black' ? 'Paspartú negro' : 'Paspartú blanco'}</div>}
              </td>
              <td>${Number(p.monto).toLocaleString('es-CL')}</td>
              <td>
                <form method="POST" action="/api/pedidos/estado">
                  <input type="hidden" name="id" value={p.id} />
                  <select class="estado-sel" name="estado" onchange="this.form.submit()">
                    {['pagado','en_enmarcado','enviado','entregado','pendiente_pago'].map(e => (
                      <option value={e} selected={p.estado === e}>{e.replace('_',' ')}</option>
                    ))}
                  </select>
                </form>
              </td>
              <td style="font-size:11px">{p.fecha_pedido || p.created_at?.slice(0,10) || '—'}</td>
              <td style="font-size:11px">{p.fecha_entrega_estimada || '—'}</td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>
</AdminLayout>
