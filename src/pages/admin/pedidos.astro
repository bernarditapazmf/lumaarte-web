---
import { isAuthenticated } from '../../lib/auth.js';
import { initDb } from '../../lib/db.js';

if (!isAuthenticated(Astro.request)) return Astro.redirect('/admin/login');

const db = await initDb();
const { rows: pedidos } = await db.execute('SELECT * FROM pedidos ORDER BY created_at DESC');
const totalVentas = pedidos.reduce((s, p) => s + (Number(p.monto) || 0), 0);
const pendientesEnvio = pedidos.filter(p => p.estado === 'en_enmarcado' || p.estado === 'pagado').length;
---
<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Pedidos — Luma Arte Admin</title>
  <meta name="robots" content="noindex" />
  <style>
    @font-face{font-family:'Mackinac';src:url('/fonts/Mackinac-Book.otf') format('opentype');font-weight:400}
    @font-face{font-family:'Mackinac';src:url('/fonts/Mackinac-BookItalic.otf') format('opentype');font-weight:400;font-style:italic}
    @font-face{font-family:'CoFo Sans';src:url('/fonts/CoFoSans-Regular.otf') format('opentype');font-weight:400}
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'CoFo Sans',system-ui,sans-serif;background:#f3f0e9;color:#211f18;min-height:100vh}
    .topbar{background:#211f18;color:#fdfcf8;display:flex;align-items:center;justify-content:space-between;padding:0 32px;height:56px;position:sticky;top:0;z-index:10}
    .topbar-brand{font-family:'Mackinac',serif;font-size:18px;letter-spacing:-.01em}
    .topbar-brand em{font-style:italic}
    .topbar-nav{display:flex;align-items:center;gap:24px}
    .topbar-link{color:rgba(253,252,248,.55);font-size:13px;text-decoration:none}
    .topbar-link:hover,.topbar-link.active{color:#fdfcf8}
    .logout-btn{background:none;border:.5px solid rgba(253,252,248,.25);color:rgba(253,252,248,.6);padding:6px 14px;border-radius:6px;font-size:12px;cursor:pointer;font-family:inherit}
    .logout-btn:hover{background:rgba(253,252,248,.1)}
    .main{max-width:1100px;margin:0 auto;padding:36px 24px}
    .header-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px}
    .section-title{font-family:'Mackinac',serif;font-size:22px;font-weight:400}
    .section-title em{font-style:italic}
    .btn-new{display:inline-flex;align-items:center;gap:6px;background:#54582f;color:#fdfcf8;text-decoration:none;padding:9px 18px;border-radius:8px;font-size:12px;letter-spacing:.04em}
    .btn-new:hover{background:#3a3d1f}
    .stats{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:28px}
    .stat{background:#fdfcf8;border:.5px solid rgba(33,31,24,.1);border-radius:10px;padding:20px 22px}
    .stat-num{font-family:'Mackinac',serif;font-size:28px;font-weight:400;margin-bottom:4px;line-height:1}
    .stat-label{font-size:11px;color:rgba(33,31,24,.45);letter-spacing:.04em;text-transform:uppercase}
    .table-wrap{background:#fdfcf8;border:.5px solid rgba(33,31,24,.1);border-radius:10px;overflow:hidden}
    table{width:100%;border-collapse:collapse}
    th{text-align:left;padding:11px 18px;font-size:10px;letter-spacing:.08em;color:rgba(33,31,24,.4);border-bottom:.5px solid rgba(33,31,24,.08);font-weight:400;text-transform:uppercase}
    td{padding:13px 18px;border-bottom:.5px solid rgba(33,31,24,.06);font-size:13px;vertical-align:middle}
    tr:last-child td{border-bottom:none}
    tr:hover td{background:#faf9f5}
    .empty{text-align:center;padding:60px 20px;color:rgba(33,31,24,.4)}
    select.estado-sel{padding:4px 8px;border:.5px solid rgba(33,31,24,.2);border-radius:5px;font-size:11px;font-family:inherit;background:#fff;cursor:pointer}
    .pill{display:inline-block;padding:3px 9px;border-radius:12px;font-size:10px}
    .pill-pagado{background:#e8eddd;color:#3a4020}
    .pill-en_enmarcado{background:#fdf3d8;color:#7a5010}
    .pill-enviado{background:#d8eafd;color:#103a7a}
    .pill-entregado{background:#d8fde8;color:#105a30}
    .pill-pendiente_pago{background:#fde8d8;color:#7a2010}
    @media(max-width:700px){
      .stats{grid-template-columns:1fr 1fr}
      th:nth-child(4),td:nth-child(4),th:nth-child(5),td:nth-child(5){display:none}
    }
  </style>
</head>
<body>
  <nav class="topbar">
    <span class="topbar-brand">Luma <em>Arte</em></span>
    <div class="topbar-nav">
      <a class="topbar-link" href="/admin">Obras</a>
      <a class="topbar-link active" href="/admin/pedidos">Pedidos</a>
      <a class="topbar-link" href="/" target="_blank">Ver sitio ↗</a>
      <form method="POST" action="/api/admin/logout">
        <button class="logout-btn" type="submit">Salir</button>
      </form>
    </div>
  </nav>

  <main class="main">
    <div class="stats">
      <div class="stat">
        <div class="stat-num">{pedidos.length}</div>
        <div class="stat-label">Total pedidos</div>
      </div>
      <div class="stat">
        <div class="stat-num">${totalVentas.toLocaleString('es-CL')}</div>
        <div class="stat-label">Total vendido</div>
      </div>
      <div class="stat">
        <div class="stat-num">{pendientesEnvio}</div>
        <div class="stat-label">Pendientes envío</div>
      </div>
    </div>

    <div class="header-row">
      <h2 class="section-title">Pedidos <em>y ventas</em></h2>
      <a class="btn-new" href="/admin/pedidos/nuevo">+ Registrar pedido</a>
    </div>

    <div class="table-wrap">
      {pedidos.length === 0 ? (
        <div class="empty">Aún no hay pedidos. Los pagos de Flow aparecerán aquí automáticamente.</div>
      ) : (
        <table>
          <thead>
            <tr>
              <th>Cliente</th>
              <th>Obra · Talla</th>
              <th>Monto</th>
              <th>Estado</th>
              <th>F. pedido</th>
              <th>F. entrega est.</th>
            </tr>
          </thead>
          <tbody>
            {pedidos.map(p => (
              <tr>
                <td>
                  <strong>{p.cliente_nombre || '—'}</strong>
                  <div style="font-size:11px;color:rgba(33,31,24,.4)">{p.cliente_email}</div>
                </td>
                <td>
                  {p.obra_nombre || '—'}
                  {p.talla && <div style="font-size:11px;color:rgba(33,31,24,.4)">{p.talla} · {p.mat === 'black' ? 'Paspartú negro' : 'Paspartú blanco'}</div>}
                </td>
                <td>${Number(p.monto).toLocaleString('es-CL')}</td>
                <td>
                  <form method="POST" action="/api/pedidos/estado">
                    <input type="hidden" name="id" value={p.id} />
                    <select class="estado-sel" name="estado" onchange="this.form.submit()">
                      {['pagado','en_enmarcado','enviado','entregado','pendiente_pago'].map(e => (
                        <option value={e} selected={p.estado === e}>{e.replace('_',' ')}</option>
                      ))}
                    </select>
                  </form>
                </td>
                <td style="font-size:12px">{p.fecha_pedido || p.created_at?.slice(0,10) || '—'}</td>
                <td style="font-size:12px">{p.fecha_entrega_estimada || '—'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>
  </main>
</body>
</html>
