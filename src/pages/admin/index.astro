---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { isAuthenticated } from '../../lib/auth.js';
import { initDb } from '../../lib/db.js';

if (!isAuthenticated(Astro.request)) return Astro.redirect('/admin/login');

const db = await initDb();
const { rows: obras } = await db.execute('SELECT * FROM obras ORDER BY orden ASC, id DESC');
const { rows: pedidos } = await db.execute('SELECT * FROM pedidos ORDER BY created_at DESC LIMIT 5');
const pendientesEnmarcador = await db.execute('SELECT COALESCE(SUM(pago_enmarcador_pendiente),0) as total FROM obras');
---
<AdminLayout title="Obras" active="obras">
  <style>
    .page-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:28px}
    h1{font-family:'Mackinac',serif;font-size:26px;font-weight:400}
    h1 em{font-style:italic}
    h2{font-family:'Mackinac',serif;font-size:20px;font-weight:400;margin-bottom:16px}
    h2 em{font-style:italic}
    .btn-new{display:inline-flex;align-items:center;gap:6px;background:#54582f;color:#fdfcf8;text-decoration:none;padding:9px 18px;border-radius:8px;font-size:12px;letter-spacing:.04em}
    .btn-new:hover{background:#3a3d1f}
    .btn-seed{background:none;border:.5px solid rgba(33,31,24,.25);color:#54582f;padding:9px 18px;border-radius:8px;font-size:12px;cursor:pointer;font-family:inherit}
    .btn-seed:hover{background:#54582f;color:#fdfcf8}
    .stats{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:32px}
    .stat{background:#fdfcf8;border:.5px solid rgba(33,31,24,.1);border-radius:10px;padding:18px 20px}
    .stat-num{font-family:'Mackinac',serif;font-size:28px;font-weight:400;line-height:1;margin-bottom:4px}
    .stat-label{font-size:10px;color:rgba(33,31,24,.45);letter-spacing:.06em;text-transform:uppercase}
    .stat-warn{color:#a05020}
    .section-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
    .table-wrap{background:#fdfcf8;border:.5px solid rgba(33,31,24,.1);border-radius:10px;overflow:hidden;margin-bottom:32px}
    table{width:100%;border-collapse:collapse}
    th{text-align:left;padding:10px 16px;font-size:10px;letter-spacing:.08em;color:rgba(33,31,24,.4);border-bottom:.5px solid rgba(33,31,24,.08);font-weight:400;text-transform:uppercase}
    td{padding:12px 16px;border-bottom:.5px solid rgba(33,31,24,.06);font-size:13px;vertical-align:middle}
    tr:last-child td{border-bottom:none}
    tr:hover td{background:#faf9f5}
    .badge{display:inline-block;padding:3px 9px;border-radius:20px;font-size:10px}
    .badge-disp{background:#e8eddd;color:#3a4020}
    .badge-vend{background:#ede8e8;color:#5a2020}
    .precios-cell{font-size:11px;color:rgba(33,31,24,.5);line-height:1.9}
    .ganancia{color:#3a4020}
    .actions{display:flex;gap:6px}
    .btn-edit{font-size:11px;color:#54582f;text-decoration:none;padding:4px 10px;border:.5px solid rgba(84,88,47,.35);border-radius:5px}
    .btn-edit:hover{background:#54582f;color:#fdfcf8}
    .btn-del{font-size:11px;color:#a33;background:none;border:.5px solid rgba(170,51,51,.3);border-radius:5px;padding:4px 10px;cursor:pointer;font-family:inherit}
    .btn-del:hover{background:#a33;color:#fff}
    .empty{text-align:center;padding:48px 20px;color:rgba(33,31,24,.4);font-size:13px}
    .pill{display:inline-block;padding:2px 8px;border-radius:12px;font-size:10px}
    .pill-pagado{background:#e8eddd;color:#3a4020}
    .pill-en_enmarcado{background:#fdf3d8;color:#7a5010}
    .pill-enviado{background:#d8eafd;color:#103a7a}
    .pill-entregado{background:#d8fde8;color:#105a30}
    .pill-pendiente_pago{background:#fde8d8;color:#7a2010}
    @media(max-width:900px){.stats{grid-template-columns:1fr 1fr}}
    @media(max-width:600px){
      th:nth-child(3),td:nth-child(3),th:nth-child(4),td:nth-child(4){display:none}
    }
  </style>

  <!-- STATS -->
  <div class="stats">
    <div class="stat">
      <div class="stat-num">{obras.length}</div>
      <div class="stat-label">Total obras</div>
    </div>
    <div class="stat">
      <div class="stat-num">{obras.filter(r => r.disponible).length}</div>
      <div class="stat-label">Disponibles</div>
    </div>
    <div class="stat">
      <div class="stat-num">{obras.filter(r => !r.disponible).length}</div>
      <div class="stat-label">Vendidas</div>
    </div>
    <div class="stat">
      <div class={`stat-num ${Number(pendientesEnmarcador.rows[0].total) > 0 ? 'stat-warn' : ''}`}>
        ${Number(pendientesEnmarcador.rows[0].total).toLocaleString('es-CL')}
      </div>
      <div class="stat-label">Pend. enmarcador</div>
    </div>
  </div>

  <!-- INVENTARIO -->
  <div class="section-header">
    <h1>Inventario de <em>obras</em></h1>
    <div style="display:flex;gap:10px">
      {obras.length === 0 && (
        <form method="POST" action="/api/admin/seed">
          <button class="btn-seed" type="submit">↓ Importar obras del sitio</button>
        </form>
      )}
      <a class="btn-new" href="/admin/nueva">+ Nueva obra</a>
    </div>
  </div>

  <div class="table-wrap">
    {obras.length === 0 ? (
      <div class="empty">Sin obras. Usa "Importar obras del sitio" o agrega manualmente.</div>
    ) : (
      <table>
        <thead>
          <tr>
            <th>Nombre</th>
            <th>Precios por talla</th>
            <th>Costos</th>
            <th>Ganancia neta</th>
            <th>Estado</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {obras.map(o => {
            const gananciaMin = (o.precio_30x40||0)-(o.costo_produccion||0)-(o.costo_enmarcado||0);
            const gananciaMax = (o.precio_50x70||0)-(o.costo_produccion||0)-(o.costo_enmarcado||0);
            return (
              <tr>
                <td>
                  <strong>{o.nombre}</strong>
                  {o.serie && <div style="font-size:11px;color:rgba(33,31,24,.4);margin-top:2px">{o.serie}</div>}
                  {o.tecnica && <div style="font-size:11px;color:rgba(33,31,24,.4)">{o.tecnica}</div>}
                </td>
                <td class="precios-cell">
                  {o.precio_30x40 ? <div>30×40 → ${Number(o.precio_30x40).toLocaleString('es-CL')}</div> : null}
                  {o.precio_40x50 ? <div>40×50 → ${Number(o.precio_40x50).toLocaleString('es-CL')}</div> : null}
                  {o.precio_50x70 ? <div>50×70 → ${Number(o.precio_50x70).toLocaleString('es-CL')}</div> : null}
                  {!o.precio_30x40 && !o.precio_40x50 && !o.precio_50x70 && <span style="color:rgba(33,31,24,.3)">Sin precio</span>}
                </td>
                <td class="precios-cell">
                  {o.costo_produccion ? <div>Prod: ${Number(o.costo_produccion).toLocaleString('es-CL')}</div> : null}
                  {o.costo_enmarcado ? <div>Enmarcado: ${Number(o.costo_enmarcado).toLocaleString('es-CL')}</div> : null}
                  {o.pago_enmarcador_pendiente ? <div style="color:#a05020">⚠ ${Number(o.pago_enmarcador_pendiente).toLocaleString('es-CL')}</div> : null}
                  {!o.costo_produccion && !o.costo_enmarcado && <span style="color:rgba(33,31,24,.3)">—</span>}
                </td>
                <td>
                  {(o.costo_produccion || o.costo_enmarcado) ? (
                    <span class="ganancia">${gananciaMin.toLocaleString('es-CL')} – ${gananciaMax.toLocaleString('es-CL')}</span>
                  ) : <span style="color:rgba(33,31,24,.3)">—</span>}
                </td>
                <td>
                  <span class={o.disponible ? 'badge badge-disp' : 'badge badge-vend'}>
                    {o.disponible ? 'Disponible' : 'Vendida'}
                  </span>
                </td>
                <td>
                  <div class="actions">
                    <a class="btn-edit" href={`/admin/editar/${o.id}`}>Editar</a>
                    <form method="POST" action="/api/obras/delete" onsubmit="return confirm('¿Eliminar esta obra?')">
                      <input type="hidden" name="id" value={o.id} />
                      <button class="btn-del" type="submit">×</button>
                    </form>
                  </div>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    )}
  </div>

  <!-- PEDIDOS RECIENTES -->
  <div class="section-header">
    <h2>Pedidos <em>recientes</em></h2>
    <a class="btn-new" href="/admin/pedidos">Ver todos →</a>
  </div>
  <div class="table-wrap">
    {pedidos.length === 0 ? (
      <div class="empty">Aún no hay pedidos registrados.</div>
    ) : (
      <table>
        <thead>
          <tr><th>Cliente</th><th>Obra</th><th>Monto</th><th>Estado</th><th>Fecha</th></tr>
        </thead>
        <tbody>
          {pedidos.map(p => (
            <tr>
              <td>{p.cliente_nombre || '—'}<br/><span style="font-size:11px;color:rgba(33,31,24,.4)">{p.cliente_email}</span></td>
              <td>{p.obra_nombre || '—'}{p.talla && <span style="font-size:11px;color:rgba(33,31,24,.4)"> · {p.talla}</span>}</td>
              <td>${Number(p.monto).toLocaleString('es-CL')}</td>
              <td><span class={`pill pill-${p.estado}`}>{p.estado?.replace('_',' ')}</span></td>
              <td style="font-size:11px">{p.fecha_pedido || p.created_at?.slice(0,10)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>
</AdminLayout>
