---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { isAuthenticated } from '../../lib/auth.js';
import { initDb } from '../../lib/db.js';

if (!isAuthenticated(Astro.request)) return Astro.redirect('/admin/login');

const db = await initDb();
const { rows: codigos } = await db.execute('SELECT * FROM codigos_descuento ORDER BY created_at DESC');
const ok = Astro.url.searchParams.get('ok');
---
<AdminLayout title="Descuentos" active="descuentos">
  <style>
    h1{font-family:'Mackinac',serif;font-size:26px;font-weight:400;margin-bottom:28px}
    h1 em{font-style:italic}
    .btn-primary{display:inline-flex;align-items:center;gap:6px;background:#54582f;color:#fdfcf8;text-decoration:none;padding:9px 18px;border-radius:8px;font-size:12px;border:none;cursor:pointer;font-family:inherit}
    .btn-primary:hover{background:#3a3d1f}
    .section-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
    .add-card{background:#fdfcf8;border:.5px solid rgba(33,31,24,.1);border-radius:10px;padding:24px;margin-bottom:28px}
    .add-card-title{font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:rgba(33,31,24,.4);margin-bottom:16px}
    .add-row{display:grid;grid-template-columns:1.5fr 1fr 1fr 1fr 1fr auto;gap:12px;align-items:end}
    .field{display:flex;flex-direction:column;gap:5px}
    label{font-size:11px;letter-spacing:.04em;color:rgba(33,31,24,.5);text-transform:uppercase}
    input,select{padding:10px 12px;border:.5px solid rgba(33,31,24,.18);border-radius:7px;font-size:13px;font-family:inherit;color:#211f18;background:#fff;outline:none;width:100%}
    input:focus,select:focus{border-color:#54582f}
    .table-wrap{background:#fdfcf8;border:.5px solid rgba(33,31,24,.1);border-radius:10px;overflow:hidden}
    table{width:100%;border-collapse:collapse}
    th{text-align:left;padding:10px 16px;font-size:10px;letter-spacing:.08em;color:rgba(33,31,24,.4);border-bottom:.5px solid rgba(33,31,24,.08);font-weight:400;text-transform:uppercase}
    td{padding:12px 16px;border-bottom:.5px solid rgba(33,31,24,.06);font-size:13px;vertical-align:middle}
    tr:last-child td{border-bottom:none}
    tr:hover td{background:#faf9f5}
    .empty{text-align:center;padding:48px 20px;color:rgba(33,31,24,.4);font-size:13px}
    .codigo-text{font-family:monospace;font-size:14px;background:#f3f0e9;padding:3px 10px;border-radius:5px;letter-spacing:.06em;color:#3a4020}
    .badge-on{display:inline-block;padding:3px 9px;border-radius:20px;font-size:10px;background:#e8eddd;color:#3a4020}
    .badge-off{display:inline-block;padding:3px 9px;border-radius:20px;font-size:10px;background:#ede8e8;color:#5a2020}
    .actions{display:flex;gap:6px}
    .btn-toggle{font-size:11px;background:none;border:.5px solid rgba(33,31,24,.2);border-radius:5px;padding:4px 10px;cursor:pointer;font-family:inherit;color:#211f18}
    .btn-toggle:hover{background:#211f18;color:#fdfcf8}
    .btn-del{font-size:11px;color:#a33;background:none;border:.5px solid rgba(170,51,51,.3);border-radius:5px;padding:4px 10px;cursor:pointer;font-family:inherit}
    .btn-del:hover{background:#a33;color:#fff}
    .success{background:#e8f5e0;border:.5px solid #a0c878;border-radius:8px;padding:12px 16px;font-size:13px;color:#3a6020;margin-bottom:20px}
    @media(max-width:900px){.add-row{grid-template-columns:1fr 1fr 1fr}}
    @media(max-width:600px){.add-row{grid-template-columns:1fr}}
  </style>

  {ok && <div class="success">✓ Código creado correctamente.</div>}

  <div class="add-card">
    <div class="add-card-title">Crear código de descuento</div>
    <form method="POST" action="/api/descuentos/create">
      <div class="add-row">
        <div class="field">
          <label>Código *</label>
          <input name="codigo" type="text" required placeholder="NAVIDAD25" style="text-transform:uppercase" />
        </div>
        <div class="field">
          <label>Tipo</label>
          <select name="tipo">
            <option value="porcentaje">% Porcentaje</option>
            <option value="fijo">$ Fijo (CLP)</option>
          </select>
        </div>
        <div class="field">
          <label>Valor</label>
          <input name="valor" type="number" min="1" required placeholder="15" />
        </div>
        <div class="field">
          <label>Usos máx.</label>
          <input name="usos_max" type="number" min="1" value="100" />
        </div>
        <div class="field">
          <label>Expira (opcional)</label>
          <input name="expira_en" type="date" />
        </div>
        <button class="btn-primary" type="submit">Crear</button>
      </div>
    </form>
  </div>

  <div class="section-header">
    <h1>Códigos de <em>descuento</em></h1>
  </div>

  <div class="table-wrap">
    {codigos.length === 0 ? (
      <div class="empty">Sin códigos creados aún.</div>
    ) : (
      <table>
        <thead>
          <tr><th>Código</th><th>Descuento</th><th>Usos</th><th>Expira</th><th>Estado</th><th></th></tr>
        </thead>
        <tbody>
          {codigos.map(c => (
            <tr>
              <td><span class="codigo-text">{c.codigo}</span></td>
              <td>{c.tipo === 'porcentaje' ? `${c.valor}%` : `$${Number(c.valor).toLocaleString('es-CL')}`}</td>
              <td>{c.usos_actual} / {c.usos_max}</td>
              <td style="font-size:12px">{c.expira_en || '—'}</td>
              <td>
                <span class={c.activo ? 'badge-on' : 'badge-off'}>
                  {c.activo ? 'Activo' : 'Inactivo'}
                </span>
              </td>
              <td>
                <div class="actions">
                  <form method="POST" action="/api/descuentos/toggle">
                    <input type="hidden" name="id" value={c.id} />
                    <input type="hidden" name="activo" value={c.activo ? '0' : '1'} />
                    <button class="btn-toggle" type="submit">{c.activo ? 'Desactivar' : 'Activar'}</button>
                  </form>
                  <form method="POST" action="/api/descuentos/delete" onsubmit="return confirm('¿Eliminar código?')">
                    <input type="hidden" name="id" value={c.id} />
                    <button class="btn-del" type="submit">×</button>
                  </form>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>
</AdminLayout>
