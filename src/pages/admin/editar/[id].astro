---
import { isAuthenticated } from '../../../lib/auth.js';
import { initDb } from '../../../lib/db.js';

if (!isAuthenticated(Astro.request)) return Astro.redirect('/admin/login');

const { id } = Astro.params;
const db = await initDb();
const { rows } = await db.execute({ sql: 'SELECT * FROM obras WHERE id = ?', args: [id] });
if (!rows.length) return Astro.redirect('/admin');
const o = rows[0];
const error = Astro.url.searchParams.get('error');
---
<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Editar obra — Luma Arte Admin</title>
  <meta name="robots" content="noindex" />
  <style>
    @font-face{font-family:'Mackinac';src:url('/fonts/Mackinac-Book.otf') format('opentype');font-weight:400}
    @font-face{font-family:'Mackinac';src:url('/fonts/Mackinac-BookItalic.otf') format('opentype');font-weight:400;font-style:italic}
    @font-face{font-family:'CoFo Sans';src:url('/fonts/CoFoSans-Regular.otf') format('opentype');font-weight:400}
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'CoFo Sans',system-ui,sans-serif;background:#f3f0e9;color:#211f18;min-height:100vh}
    .topbar{background:#211f18;color:#fdfcf8;display:flex;align-items:center;justify-content:space-between;padding:0 32px;height:56px}
    .topbar-brand{font-family:'Mackinac',serif;font-size:18px;letter-spacing:-.01em}
    .topbar-brand em{font-style:italic}
    .back{color:rgba(253,252,248,.6);font-size:13px;text-decoration:none}
    .back:hover{color:#fdfcf8}
    .main{max-width:720px;margin:0 auto;padding:36px 24px}
    h1{font-family:'Mackinac',serif;font-size:26px;font-weight:400;margin-bottom:28px}
    h1 em{font-style:italic}
    .card{background:#fdfcf8;border:.5px solid rgba(33,31,24,.1);border-radius:10px;padding:28px;margin-bottom:20px}
    .card-title{font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:rgba(33,31,24,.4);margin-bottom:20px;padding-bottom:12px;border-bottom:.5px solid rgba(33,31,24,.08)}
    .row{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px}
    .row.tri{grid-template-columns:1fr 1fr 1fr}
    .row.full{grid-template-columns:1fr}
    .field{display:flex;flex-direction:column;gap:5px}
    label{font-size:11px;letter-spacing:.04em;color:rgba(33,31,24,.5);text-transform:uppercase}
    input,select,textarea{padding:10px 12px;border:.5px solid rgba(33,31,24,.18);border-radius:7px;font-size:14px;font-family:inherit;color:#211f18;background:#fff;outline:none;width:100%}
    input:focus,select:focus,textarea:focus{border-color:#54582f}
    textarea{resize:vertical;min-height:72px}
    .check-row{display:flex;align-items:center;gap:10px;margin-top:4px}
    input[type=checkbox]{width:17px;height:17px;accent-color:#54582f;cursor:pointer;flex-shrink:0}
    .actions{display:flex;gap:12px;margin-top:24px}
    .btn-save{flex:1;padding:12px;background:#54582f;color:#fdfcf8;border:none;border-radius:8px;font-size:13px;cursor:pointer;font-family:inherit}
    .btn-save:hover{background:#3a3d1f}
    .btn-cancel{padding:12px 20px;background:none;border:.5px solid rgba(33,31,24,.2);border-radius:8px;font-size:13px;color:#211f18;text-decoration:none;text-align:center}
    .error{background:#fde8e8;border:.5px solid #e8b4b4;border-radius:8px;padding:12px 16px;font-size:13px;color:#a33;margin-bottom:16px}
    .hint{font-size:11px;color:rgba(33,31,24,.4);margin-top:3px}
    @media(max-width:600px){.row,.row.tri{grid-template-columns:1fr}}
  </style>
</head>
<body>
  <nav class="topbar">
    <span class="topbar-brand">Luma <em>Arte</em></span>
    <a class="back" href="/admin">← Inventario</a>
  </nav>
  <main class="main">
    <h1>Editar <em>{o.nombre}</em></h1>
    {error && <div class="error">Error al guardar. Intenta nuevamente.</div>}

    <form method="POST" action="/api/obras/update">
      <input type="hidden" name="id" value={o.id} />

      <!-- INFO GENERAL -->
      <div class="card">
        <div class="card-title">Información general</div>
        <div class="row">
          <div class="field">
            <label>Nombre *</label>
            <input name="nombre" type="text" required value={o.nombre} />
          </div>
          <div class="field">
            <label>Serie</label>
            <input name="serie" type="text" value={o.serie ?? ''} placeholder="Volcanes, Botanicas…" />
          </div>
        </div>
        <div class="row">
          <div class="field">
            <label>Técnica</label>
            <select name="tecnica">
              <option value="">— Seleccionar —</option>
              {['Técnica mixta','Acuarela sobre papel','Pastel al óleo sobre papel','Bordado sobre papel'].map(t => (
                <option selected={o.tecnica === t}>{t}</option>
              ))}
            </select>
          </div>
          <div class="field">
            <label>Imagen (archivo)</label>
            <input name="imagen" type="text" value={o.imagen ?? ''} placeholder="obra1.png" />
          </div>
        </div>
        <div class="row">
          <div class="field">
            <label>Orden en sitio</label>
            <input name="orden" type="number" min="0" value={o.orden ?? 0} />
          </div>
          <div class="field" style="justify-content:flex-end">
            <div class="check-row">
              <input id="disponible" name="disponible" type="checkbox" checked={!!o.disponible} />
              <label for="disponible" style="text-transform:none;font-size:14px;letter-spacing:0">Disponible para venta</label>
            </div>
          </div>
        </div>
      </div>

      <!-- PRECIOS -->
      <div class="card">
        <div class="card-title">Precios por talla (CLP)</div>
        <div class="row tri">
          <div class="field">
            <label>30 × 40 cm</label>
            <input name="precio_30x40" type="number" min="0" value={o.precio_30x40 ?? ''} />
          </div>
          <div class="field">
            <label>40 × 50 cm</label>
            <input name="precio_40x50" type="number" min="0" value={o.precio_40x50 ?? ''} />
          </div>
          <div class="field">
            <label>50 × 70 cm</label>
            <input name="precio_50x70" type="number" min="0" value={o.precio_50x70 ?? ''} />
          </div>
        </div>
      </div>

      <!-- COSTOS -->
      <div class="card">
        <div class="card-title">Costos y finanzas</div>
        <div class="row tri">
          <div class="field">
            <label>Costo producción</label>
            <input name="costo_produccion" type="number" min="0" value={o.costo_produccion ?? ''} placeholder="0" />
            <span class="hint">Materiales, horas</span>
          </div>
          <div class="field">
            <label>Costo enmarcado</label>
            <input name="costo_enmarcado" type="number" min="0" value={o.costo_enmarcado ?? ''} placeholder="0" />
            <span class="hint">Valor enmarcador</span>
          </div>
          <div class="field">
            <label>Pendiente enmarcador</label>
            <input name="pago_enmarcador_pendiente" type="number" min="0" value={o.pago_enmarcador_pendiente ?? ''} placeholder="0" />
            <span class="hint">Sin pagar aún</span>
          </div>
        </div>
        {(o.costo_produccion || o.costo_enmarcado) ? (
          <div style="background:#f3f0e9;border-radius:7px;padding:12px 16px;font-size:13px;margin-top:4px">
            Ganancia neta estimada:
            <strong style="color:#3a4020"> ${((o.precio_30x40||0)-(o.costo_produccion||0)-(o.costo_enmarcado||0)).toLocaleString('es-CL')}</strong> (30×40) —
            <strong style="color:#3a4020"> ${((o.precio_50x70||0)-(o.costo_produccion||0)-(o.costo_enmarcado||0)).toLocaleString('es-CL')}</strong> (50×70)
          </div>
        ) : null}
      </div>

      <!-- NOTAS -->
      <div class="card">
        <div class="card-title">Notas internas</div>
        <div class="row full">
          <div class="field">
            <textarea name="notas" placeholder="Observaciones, estado físico, ubicación de la obra…">{o.notas ?? ''}</textarea>
          </div>
        </div>
      </div>

      <div class="actions">
        <a class="btn-cancel" href="/admin">Cancelar</a>
        <button class="btn-save" type="submit">Guardar cambios</button>
      </div>
    </form>
  </main>
</body>
</html>
