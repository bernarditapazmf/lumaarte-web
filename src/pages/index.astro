<script>
// ── DATOS ──────────────────────────────────────────
const OBRAS = [
  { base:'obra1', title:'Dúo Lilium y Volcanes I',  disponible:true,  horizontal:false },
  { base:'obra2', title:'Dúo Lilium y Volcanes II', disponible:false, horizontal:false },
  { base:'obra3', title:'Rostro de Chilcos',         disponible:true,  horizontal:false },
  { base:'obra4', title:'Mujer Hortensia',           disponible:true,  horizontal:false },
  { base:'obra5', title:'Bosque de Arrayanes',       disponible:true,  horizontal:true  },
];
const SIZES = ['30 × 40 cm','40 × 50 cm','50 × 70 cm'];
const GC_IMGS = ['/img/gc1.jpg','/img/gc2.jpg','/img/gc3.jpg','/img/gc4.jpg','/img/gc5.jpg','/img/gc6.jpg'];

// ── ESTADO ─────────────────────────────────────────
const S = {
  activeObra: null,
  sizes: {},
  mat: {},
  cart: [],
  gc: { design:0, de:'', para:'', mail:'', mensaje:'', amount:null, other:'' },
};

// ── COLLAGE ─────────────────────────────────────────
function fitCollage(){
  const wrap = document.getElementById('collage-wrap');
  const stage = document.getElementById('collage-stage');
  if(!wrap||!stage) return;
  const s = Math.min(1, wrap.clientWidth/1180);
  stage.style.transform = `scale(${s})`;
  wrap.style.height = (620*s)+'px';
}
window.addEventListener('resize', fitCollage);
document.fonts && document.fonts.ready.then(()=>fitCollage());
setTimeout(fitCollage,300);

// ── RENDER OBRAS ────────────────────────────────────
function renderObras(){
  const grid = document.getElementById('obras-grid');
  grid.innerHTML = OBRAS.map((o,i) => {
    const mat = S.mat[i]||'white';
    const selSize = S.sizes[i]||null;
    const isActive = S.activeObra === i;
    const imgSrc = `/img/${o.base}_${mat}.png`;
    const horizontal = o.horizontal;
    return `
    <div class="obra-cell${horizontal?' obra-cell--horizontal':''}">
      <div class="obra-frame obra-frame--${horizontal?'horizontal':'vertical'}${!o.disponible?' obra-frame--vendida':''}"
           ${o.disponible?`onclick="toggleObra(${i})"`:''}>
        <img class="obra-img" src="${imgSrc}" alt="${o.title}" />
        <div class="obra-badge${isActive?' hidden':''}">
          <span class="obra-dot obra-dot--${o.disponible?'disp':'vend'}"></span>
          <span class="obra-badge-txt">${o.disponible?'Disponible':'Vendida'}</span>
        </div>
        <div class="obra-overlay${isActive?' active':''}">
          <div>
            <div class="obra-sizes-label">Elige el tamaño</div>
            <div class="obra-sizes">
              ${SIZES.map(sz=>`
                <button class="obra-size-btn${selSize===sz?' selected':''}"
                  onclick="event.stopPropagation();selectSize(${i},'${sz}')">
                  ${sz}
                </button>`).join('')}
            </div>
          </div>
          <button class="obra-comprar" onclick="event.stopPropagation();comprar(${i})">
            Comprar →
          </button>
        </div>
      </div>
      <div class="obra-info">
        <div class="obra-title">${o.title}</div>
        <div class="obra-desc">Técnica mixta. Acuarela, pastel al óleo, hilo sobre papel.</div>
        <div class="obra-mat-label">Paspartú</div>
        <div class="obra-mat-btns">
          <button class="obra-mat-btn${mat==='white'?' active':''}" onclick="setMat(${i},'white')">Blanco</button>
          <button class="obra-mat-btn${mat==='black'?' active':''}" onclick="setMat(${i},'black')">Negro</button>
        </div>
      </div>
    </div>`;
  }).join('');
}

// ── OBRAS HANDLERS ──────────────────────────────────
window.toggleObra = (i)=>{
  S.activeObra = S.activeObra===i ? null : i;
  renderObras();
};
window.setMat = (i,val)=>{
  S.mat[i]=val;
  renderObras();
};
window.selectSize = (i,label)=>{
  S.sizes[i]=label;
  renderObras();
};
window.comprar = (i)=>{
  const o = OBRAS[i];
  const mat = S.mat[i]||'white';
  const size = S.sizes[i]||'30 × 40 cm';
  S.cart.push({ title:o.title, img:`/img/${o.base}_${mat}.png`, detail:`Técnica mixta · ${size}`, key:Date.now()+'-'+i });
  S.activeObra = null;
  renderObras();
  renderCart();
  openCart();
};

// ── CART ────────────────────────────────────────────
function openCart(){
  document.getElementById('cart-drawer').classList.add('open');
  document.getElementById('cart-scrim').classList.add('open');
}
function closeCart(){
  document.getElementById('cart-drawer').classList.remove('open');
  document.getElementById('cart-scrim').classList.remove('open');
}
window.removeItem = (key)=>{
  S.cart = S.cart.filter(c=>c.key!==key);
  renderCart();
};
function renderCart(){
  const count = S.cart.length;
  document.getElementById('cart-count-nav').textContent = `(${count})`;
  document.getElementById('cart-count-drawer').textContent = `(${count})`;
  const body = document.getElementById('cart-body');
  if(count===0){
    body.innerHTML = `<div class="cart-empty">
      <div class="cart-empty-title">Tu carrito está vacío.</div>
      <p class="cart-empty-sub">Elige una obra y su tamaño para agregarla aquí.</p>
    </div>`;
    return;
  }
  body.innerHTML = S.cart.map(c=>`
    <div class="cart-item">
      <img class="cart-item-img" src="${c.img}" alt="${c.title}" />
      <div style="flex:1">
        <div class="cart-item-title">${c.title}</div>
        <div class="cart-item-detail">${c.detail}</div>
        <button class="cart-item-remove" onclick="removeItem('${c.key}')">Quitar</button>
      </div>
    </div>`).join('')
  + `<p class="cart-note">Coordinamos el envío y embalaje de cada obra contigo. Los valores se confirman al finalizar.</p>`;
}

document.getElementById('btn-cart').addEventListener('click', openCart);
document.getElementById('btn-cart-close').addEventListener('click', closeCart);
document.getElementById('cart-scrim').addEventListener('click', closeCart);

// ── GIFTCARD ────────────────────────────────────────
const GC_LABELS = ['Dunas de tela','Cascada de bruma','Follaje en viento','Vuelo de cisnes','Pradera al viento','Manos de luz'];

function clp(n){ return '$'+Math.round(n).toLocaleString('es-CL'); }

function gcMontoValor(){
  if(S.gc.amount==='otro'){
    return parseInt(String(S.gc.other||'').replace(/\D/g,''),10)||0;
  }
  return typeof S.gc.amount==='number' ? S.gc.amount : 0;
}

function updateGCPreview(){
  const gc = S.gc;
  const preview = document.getElementById('gc-preview');
  preview.style.backgroundImage = `url(${GC_IMGS[gc.design]})`;
  preview.style.backgroundSize = 'cover';
  preview.style.backgroundPosition = 'center';
  document.getElementById('gc-monto-lbl').textContent = gcMontoValor()>0 ? clp(gcMontoValor()) : '$ —';
  document.getElementById('gc-para-preview').textContent = gc.para||'nombre';
  document.getElementById('gc-de-preview').textContent = gc.de||'nombre';
  document.getElementById('gc-mensaje-preview').textContent = gc.mensaje||'Tu dedicatoria aparecerá aquí…';

  // Amounts
  document.querySelectorAll('.gc-amount-btn').forEach(btn=>{
    const v = btn.dataset.val;
    const active = v==='otro' ? gc.amount==='otro' : parseInt(v)===gc.amount;
    btn.classList.toggle('active',active);
  });
  // Other input
  document.getElementById('gc-other-wrap').style.display = gc.amount==='otro'?'block':'none';

  // Validate
  const emailOk = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(String(gc.mail||'').trim());
  const monto = gcMontoValor();
  const complete = !!String(gc.de).trim()&&!!String(gc.para).trim()&&emailOk&&!!String(gc.mensaje).trim()&&monto>0;
  const btn = document.getElementById('gc-add-btn');
  const hint = document.getElementById('gc-hint');
  btn.className = `gc-btn ${complete?'gc-btn--active':'gc-btn--disabled'}`;
  btn.disabled = !complete;
  if(complete){
    hint.textContent='La enviaremos por correo a quien indiques una vez confirmado el pago.';
    hint.style.color='rgba(33,31,24,.5)';
  } else if(monto<=0){
    hint.textContent='Elige o escribe un monto para continuar.';
    hint.style.color='#9a4a2a';
  } else if(!emailOk){
    hint.textContent='Ingresa un correo válido de quien recibe.';
    hint.style.color='#9a4a2a';
  } else {
    hint.textContent='Completa todos los campos para agregar la giftcard.';
    hint.style.color='#9a4a2a';
  }
}

document.getElementById('gc-design').addEventListener('change',e=>{
  S.gc.design=parseInt(e.target.value)||0; updateGCPreview();
});
document.querySelectorAll('.gc-amount-btn').forEach(btn=>{
  btn.addEventListener('click',()=>{
    const v = btn.dataset.val;
    S.gc.amount = v==='otro'?'otro':parseInt(v);
    updateGCPreview();
  });
});
document.getElementById('gc-other-input').addEventListener('input',e=>{
  S.gc.other=e.target.value; updateGCPreview();
});
document.getElementById('gc-de').addEventListener('input',e=>{ S.gc.de=e.target.value; updateGCPreview(); });
document.getElementById('gc-para').addEventListener('input',e=>{ S.gc.para=e.target.value; updateGCPreview(); });
document.getElementById('gc-mail').addEventListener('input',e=>{ S.gc.mail=e.target.value; updateGCPreview(); });
document.getElementById('gc-mensaje').addEventListener('input',e=>{ S.gc.mensaje=e.target.value; updateGCPreview(); });

document.getElementById('gc-add-btn').addEventListener('click',()=>{
  const gc = S.gc;
  const emailOk = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(String(gc.mail||'').trim());
  const monto = gcMontoValor();
  const complete = !!String(gc.de).trim()&&!!String(gc.para).trim()&&emailOk&&!!String(gc.mensaje).trim()&&monto>0;
  if(!complete) return;
  const design = GC_LABELS[gc.design]||GC_LABELS[0];
  S.cart.push({ title:`Giftcard — ${design}`, img:GC_IMGS[gc.design], detail:`Envío digital · ${clp(monto)}`, key:Date.now()+'-gc' });
  renderCart();
  openCart();
});

// ── INIT ────────────────────────────────────────────
renderObras();
updateGCPreview();
fitCollage();
</script>
</body>
</html>
