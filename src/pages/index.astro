<script>
// ── DATOS ──────────────────────────────────────────
// ── PRECIOS: actualiza estos valores antes de publicar ─
const OBRAS = [
  { base:'obra1', title:'Dúo Lilium y Volcanes I',  disponible:true, horizontal:false,
    precios:{'30 × 40 cm':95000,'40 × 50 cm':145000,'50 × 70 cm':220000} },
  { base:'obra2', title:'Dúo Lilium y Volcanes II', disponible:true, horizontal:false,
    precios:{'30 × 40 cm':95000,'40 × 50 cm':145000,'50 × 70 cm':220000} },
  { base:'obra3', title:'Rostro de Chilcos',         disponible:true, horizontal:false, imgPos:'top center',
    precios:{'30 × 40 cm':95000,'40 × 50 cm':145000,'50 × 70 cm':220000} },
  { base:'obra4', title:'Mujer Hortensia',           disponible:true, horizontal:false,
    precios:{'30 × 40 cm':95000,'40 × 50 cm':145000,'50 × 70 cm':220000} },
  { base:'obra5', title:'Bosque de Arrayanes',       disponible:true, horizontal:true,
    precios:{'30 × 40 cm':95000,'40 × 50 cm':145000,'50 × 70 cm':220000} },
];
const SIZES = ['30 × 40 cm','40 × 50 cm','50 × 70 cm'];
const GC_IMGS = ['/img/gc1.jpg','/img/gc2.jpg','/img/gc3.jpg','/img/gc4.jpg','/img/gc5.jpg','/img/gc6.jpg'];

// ── ESTADO ─────────────────────────────────────────
const S = {
  activeObra: null,
  sizes: {},
  mat: {},
  cart: [],
  gc: { design:0, de:'', para:'', mail:'', mensaje:'', amount:null, other:'' },
};

// ── COLLAGE ─────────────────────────────────────────
function fitCollage(){
  const wrap = document.getElementById('collage-wrap');
  const stage = document.getElementById('collage-stage');
  if(!wrap||!stage) return;
  const s = Math.min(1, wrap.clientWidth/1180);
  stage.style.transform = `scale(${s})`;
  wrap.style.height = (620*s)+'px';
}
window.addEventListener('resize', fitCollage);
document.fonts && document.fonts.ready.then(()=>fitCollage());
setTimeout(fitCollage,300);

// ── RENDER OBRAS (una sola vez) ─────────────────────
function renderObras(){
  const grid = document.getElementById('obras-grid');
  grid.innerHTML = OBRAS.map((o,i) => {
    const horizontal = o.horizontal;
    return `
    <div class="obra-cell${horizontal?' obra-cell--horizontal':''}">
      <div id="obra-frame-${i}" class="obra-frame obra-frame--${horizontal?'horizontal':'vertical'}${!o.disponible?' obra-frame--vendida':''}">
        <img id="obra-img-${i}" class="obra-img" src="/img/${o.base}_white.png" alt="${o.title}" ${o.imgPos?`style="object-position:${o.imgPos}"`:''}  />
        <div id="obra-badge-${i}" class="obra-badge">
          <span class="obra-dot obra-dot--${o.disponible?'disp':'vend'}"></span>
          <span class="obra-badge-txt">${o.disponible?'Disponible':'Vendida'}</span>
        </div>
        <div id="obra-overlay-${i}" class="obra-overlay">
          <div>
            <div class="obra-sizes-label">Elige el tamaño</div>
            <div class="obra-sizes">
              ${SIZES.map(sz=>`
                <button class="obra-size-btn" data-obra="${i}" data-size="${sz}"
                  onclick="event.stopPropagation();selectSize(${i},'${sz}')">
                  ${sz}
                </button>`).join('')}
            </div>
          </div>
          <div class="obra-overlay-bottom">
            <button class="obra-cerrar" onclick="event.stopPropagation();closeObra(${i})">Cancelar</button>
            <button class="obra-comprar" onclick="event.stopPropagation();comprar(${i})">Comprar →</button>
          </div>
        </div>
      </div>
      <div class="obra-info">
        <div class="obra-title">${o.title}</div>
        <div class="obra-desc">Técnica mixta · Acuarela, pastel al óleo, hilo sobre papel.</div>
        <div class="obra-mat-label">Paspartú</div>
        <div class="obra-mat-btns">
          <button class="obra-mat-btn active" data-obra="${i}" data-mat="white" onclick="setMat(${i},'white')">Blanco</button>
          <button class="obra-mat-btn" data-obra="${i}" data-mat="black" onclick="setMat(${i},'black')">Negro</button>
        </div>
      </div>
    </div>`;
  }).join('');

  OBRAS.forEach((o,i)=>{
    if(o.disponible){
      document.getElementById(`obra-frame-${i}`).addEventListener('click',()=>toggleObra(i));
    }
  });
}

// ── OBRAS HANDLERS (solo DOM, sin re-render) ────────
window.toggleObra = (i)=>{
  if(S.activeObra===i){ closeObra(i); return; }
  if(S.activeObra!==null) closeObra(S.activeObra);
  S.activeObra=i;
  document.getElementById(`obra-frame-${i}`).classList.add('is-open');
  document.getElementById(`obra-overlay-${i}`).classList.add('active');
  document.getElementById(`obra-badge-${i}`).classList.add('hidden');
};
window.closeObra = (i)=>{
  document.getElementById(`obra-frame-${i}`).classList.remove('is-open');
  document.getElementById(`obra-overlay-${i}`).classList.remove('active');
  document.getElementById(`obra-badge-${i}`).classList.remove('hidden');
  if(S.activeObra===i) S.activeObra=null;
};
window.setMat = (i,val)=>{
  S.mat[i]=val;
  document.getElementById(`obra-img-${i}`).src=`/img/${OBRAS[i].base}_${val}.png`;
  document.querySelectorAll(`.obra-mat-btn[data-obra="${i}"]`).forEach(b=>{
    b.classList.toggle('active', b.dataset.mat===val);
  });
};
window.selectSize = (i,sz)=>{
  S.sizes[i]=sz;
  document.querySelectorAll(`.obra-size-btn[data-obra="${i}"]`).forEach(b=>{
    b.classList.toggle('selected', b.dataset.size===sz);
  });
};
window.comprar = (i)=>{
  const o=OBRAS[i];
  const size=S.sizes[i]||'30 × 40 cm';
  const precio=o.precios[size]||0;
  const matLabel=S.mat[i]==='black'?'Paspartú negro':'Paspartú blanco';
  S.cart.push({title:o.title,img:`/img/${o.base}.png`,detail:`${size} · ${matLabel}`,precio,key:Date.now()+'-'+i});
  closeObra(i);
  renderCart();
  openCart();
};

// ── CART ────────────────────────────────────────────
function openCart(){
  document.getElementById('cart-drawer').classList.add('open');
  document.getElementById('cart-scrim').classList.add('open');
}
function closeCart(){
  document.getElementById('cart-drawer').classList.remove('open');
  document.getElementById('cart-scrim').classList.remove('open');
}
window.removeItem = (key)=>{
  S.cart = S.cart.filter(c=>c.key!==key);
  renderCart();
};
function renderCart(){
  const count = S.cart.length;
  document.getElementById('cart-count-nav').textContent = `(${count})`;
  document.getElementById('cart-count-drawer').textContent = `(${count})`;
  const body = document.getElementById('cart-body');
  if(count===0){
    body.innerHTML = `<div class="cart-empty">
      <div class="cart-empty-title">Tu carrito está vacío.</div>
      <p class="cart-empty-sub">Elige una obra y su tamaño para agregarla aquí.</p>
    </div>`;
    document.getElementById('cart-total-wrap').style.display='none';
    return;
  }
  const total = S.cart.reduce((s,c)=>s+(c.precio||0),0);
  body.innerHTML = S.cart.map(c=>`
    <div class="cart-item">
      <div class="cart-item-thumb"><img src="${c.img}" alt="${c.title}" /></div>
      <div style="flex:1;min-width:0">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:8px">
          <div class="cart-item-title">${c.title}</div>
          <div class="cart-item-price">${c.precio?clp(c.precio):''}</div>
        </div>
        <div class="cart-item-detail">${c.detail}</div>
        <button class="cart-item-remove" onclick="removeItem('${c.key}')">Quitar</button>
      </div>
    </div>`).join('')
  + `<p class="cart-note">Coordinamos envío y embalaje contigo. Los valores son referenciales.</p>`;
  const tw = document.getElementById('cart-total-wrap');
  tw.style.display='flex';
  document.getElementById('cart-total-val').textContent = clp(total);
}

document.getElementById('btn-cart').addEventListener('click', openCart);
document.getElementById('btn-cart-close').addEventListener('click', closeCart);
document.getElementById('cart-scrim').addEventListener('click', closeCart);

// ── GIFTCARD ────────────────────────────────────────
const GC_LABELS = ['Dunas de tela','Cascada de bruma','Follaje en viento','Vuelo de cisnes','Pradera al viento','Manos de luz'];

function clp(n){ return '$'+Math.round(n).toLocaleString('es-CL'); }

function gcMontoValor(){
  if(S.gc.amount==='otro'){
    return parseInt(String(S.gc.other||'').replace(/\D/g,''),10)||0;
  }
  return typeof S.gc.amount==='number' ? S.gc.amount : 0;
}

function updateGCPreview(){
  const gc = S.gc;
  const preview = document.getElementById('gc-preview');
  preview.style.backgroundImage = `url(${GC_IMGS[gc.design]})`;
  preview.style.backgroundSize = 'cover';
  preview.style.backgroundPosition = 'center';
  document.getElementById('gc-monto-lbl').textContent = gcMontoValor()>0 ? clp(gcMontoValor()) : '$ —';
  document.getElementById('gc-para-preview').textContent = gc.para||'nombre';
  document.getElementById('gc-de-preview').textContent = gc.de||'nombre';
  document.getElementById('gc-mensaje-preview').textContent = gc.mensaje||'Tu dedicatoria aparecerá aquí…';

  // Amounts
  document.querySelectorAll('.gc-amount-btn').forEach(btn=>{
    const v = btn.dataset.val;
    const active = v==='otro' ? gc.amount==='otro' : parseInt(v)===gc.amount;
    btn.classList.toggle('active',active);
  });
  // Other input
  document.getElementById('gc-other-wrap').style.display = gc.amount==='otro'?'block':'none';

  // Validate
  const emailOk = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(String(gc.mail||'').trim());
  const monto = gcMontoValor();
  const complete = !!String(gc.de).trim()&&!!String(gc.para).trim()&&emailOk&&!!String(gc.mensaje).trim()&&monto>0;
  const btn = document.getElementById('gc-add-btn');
  const hint = document.getElementById('gc-hint');
  btn.className = `gc-btn ${complete?'gc-btn--active':'gc-btn--disabled'}`;
  btn.disabled = !complete;
  if(complete){
    hint.textContent='La enviaremos por correo a quien indiques una vez confirmado el pago.';
    hint.style.color='rgba(33,31,24,.5)';
  } else if(monto<=0){
    hint.textContent='Elige o escribe un monto para continuar.';
    hint.style.color='#9a4a2a';
  } else if(!emailOk){
    hint.textContent='Ingresa un correo válido de quien recibe.';
    hint.style.color='#9a4a2a';
  } else {
    hint.textContent='Completa todos los campos para agregar la giftcard.';
    hint.style.color='#9a4a2a';
  }
}

document.getElementById('gc-design').addEventListener('change',e=>{
  S.gc.design=parseInt(e.target.value)||0; updateGCPreview();
});
document.querySelectorAll('.gc-amount-btn').forEach(btn=>{
  btn.addEventListener('click',()=>{
    const v = btn.dataset.val;
    S.gc.amount = v==='otro'?'otro':parseInt(v);
    updateGCPreview();
  });
});
document.getElementById('gc-other-input').addEventListener('input',e=>{
  S.gc.other=e.target.value; updateGCPreview();
});
document.getElementById('gc-de').addEventListener('input',e=>{ S.gc.de=e.target.value; updateGCPreview(); });
document.getElementById('gc-para').addEventListener('input',e=>{ S.gc.para=e.target.value; updateGCPreview(); });
document.getElementById('gc-mail').addEventListener('input',e=>{ S.gc.mail=e.target.value; updateGCPreview(); });
document.getElementById('gc-mensaje').addEventListener('input',e=>{ S.gc.mensaje=e.target.value; updateGCPreview(); });

document.getElementById('gc-add-btn').addEventListener('click',()=>{
  const gc = S.gc;
  const emailOk = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(String(gc.mail||'').trim());
  const monto = gcMontoValor();
  const complete = !!String(gc.de).trim()&&!!String(gc.para).trim()&&emailOk&&!!String(gc.mensaje).trim()&&monto>0;
  if(!complete) return;
  const design = GC_LABELS[gc.design]||GC_LABELS[0];
  S.cart.push({ title:`Giftcard — ${design}`, img:GC_IMGS[gc.design], detail:`Envío digital · ${clp(monto)}`, key:Date.now()+'-gc' });
  renderCart();
  openCart();
});

// ── MODAL PEDIDO ─────────────────────────────────────
function openPedido(){
  if(S.cart.length===0) return;
  const total=S.cart.reduce((s,c)=>s+(c.precio||0),0);

  // Resumen de ítems
  document.getElementById('pedido-items').innerHTML=S.cart.map(c=>`
    <div class="pedido-item">
      <div class="pedido-item-name">
        ${c.title}
        <span class="pedido-item-det">${c.detail}</span>
      </div>
      <div class="pedido-item-val">${c.precio?clp(c.precio):''}</div>
    </div>`).join('');
  document.getElementById('pedido-total').textContent=clp(total);

  // Resetear form/estado
  document.getElementById('pedido-form').reset();
  document.getElementById('pedido-form-wrap').style.display='block';
  document.getElementById('pedido-ok').style.display='none';
  document.getElementById('pedido-submit-btn').disabled=false;
  document.getElementById('pedido-submit-btn').textContent='Enviar pedido →';

  document.getElementById('pedido-scrim').classList.add('open');
  document.getElementById('pedido-modal').classList.add('open');
  closeCart();
}
function closePedido(){
  document.getElementById('pedido-scrim').classList.remove('open');
  document.getElementById('pedido-modal').classList.remove('open');
}
window.closePedidoModal=function(){
  closePedido();
  window.scrollTo({top:0,behavior:'smooth'});
};
document.getElementById('btn-pedido-close').addEventListener('click',closePedido);
document.getElementById('pedido-scrim').addEventListener('click',closePedido);
document.querySelector('.cart-checkout').addEventListener('click',openPedido);

document.getElementById('pedido-form').addEventListener('submit',async(e)=>{
  e.preventDefault();
  const btn=document.getElementById('pedido-submit-btn');
  btn.disabled=true;
  btn.textContent='Redirigiendo a pago…';
  const fd=new FormData(e.target);
  const total=S.cart.reduce((s,c)=>s+(c.precio||0),0);
  const payload={
    nombre: fd.get('nombre'),
    email:  fd.get('email'),
    telefono: fd.get('telefono')||'',
    direccion: fd.get('direccion')||'',
    ciudad: fd.get('ciudad')||'',
    region: fd.get('region')||'',
    mensaje: fd.get('mensaje')||'',
    total,
    items: S.cart.map(c=>({title:c.title,detail:c.detail,precio:c.precio})),
  };
  try{
    const res=await fetch('/api/payment-create',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify(payload),
    });
    const json=await res.json();
    if(json.redirectUrl){
      window.location.href=json.redirectUrl;
    } else {
      btn.disabled=false;
      btn.textContent='Reintentar →';
      alert('Error al crear pago: '+(json.error||'intenta de nuevo'));
    }
  } catch(err){
    btn.disabled=false;
    btn.textContent='Reintentar →';
    alert('Error de conexión: '+err.message);
  }
});

// ── INIT ────────────────────────────────────────────
renderObras();
updateGCPreview();
fitCollage();

// ── FORMULARIO COLABOREMOS ───────────────────────────
document.getElementById('btn-colab-send').addEventListener('click', async () => {
  const nombre  = document.getElementById('colab-nombre').value.trim();
  const email   = document.getElementById('colab-email').value.trim();
  const mensaje = document.getElementById('colab-mensaje').value.trim();
  const okEl    = document.getElementById('colab-ok');
  const errEl   = document.getElementById('colab-err');
  const btn     = document.getElementById('btn-colab-send');
  okEl.style.display = 'none';
  errEl.style.display = 'none';
  if (!nombre || !email) { errEl.textContent = 'Por favor completa tu nombre y correo.'; errEl.style.display = 'block'; return; }
  btn.disabled = true;
  btn.textContent = 'Enviando…';
  try {
    const res = await fetch('/api/contacto', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ nombre, email, mensaje }),
    });
    if (res.ok) {
      okEl.style.display = 'block';
      document.getElementById('colab-nombre').value = '';
      document.getElementById('colab-email').value = '';
      document.getElementById('colab-mensaje').value = '';
    } else { errEl.style.display = 'block'; }
  } catch { errEl.style.display = 'block'; }
  btn.disabled = false;
  btn.textContent = 'Enviar mensaje';
});
</script>
</body>
