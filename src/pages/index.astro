<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Luma Arte — Arte patagónico del sur de Chile</title>
<meta name="description" content="Arte original inspirado en la naturaleza del sur de Chile. Acuarela, pastel al óleo y bordado sobre papel. Por B. Mir." />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Spline+Sans+Mono:wght@400;500&family=Caveat:wght@400;500&display=swap" rel="stylesheet" />
<style>
@font-face{font-family:'Mackinac';src:url('/fonts/Mackinac-Book.otf') format('opentype');font-weight:400;font-style:normal;font-display:swap}
@font-face{font-family:'Mackinac';src:url('/fonts/Mackinac-BookItalic.otf') format('opentype');font-weight:400;font-style:italic;font-display:swap}
@font-face{font-family:'Mackinac';src:url('/fonts/Mackinac-Medium.otf') format('opentype');font-weight:500;font-style:normal;font-display:swap}
@font-face{font-family:'Mackinac';src:url('/fonts/Mackinac-MediumItalic.otf') format('opentype');font-weight:500;font-style:italic;font-display:swap}
@font-face{font-family:'Mackinac';src:url('/fonts/Mackinac-Bold.otf') format('opentype');font-weight:700;font-style:normal;font-display:swap}
@font-face{font-family:'CoFo Sans';src:url('/fonts/CoFoSans-Light.otf') format('opentype');font-weight:300;font-style:normal;font-display:swap}
@font-face{font-family:'CoFo Sans';src:url('/fonts/CoFoSans-Regular.otf') format('opentype');font-weight:400;font-style:normal;font-display:swap}
@font-face{font-family:'CoFo Sans';src:url('/fonts/CoFoSans-Italic.otf') format('opentype');font-weight:400;font-style:italic;font-display:swap}
@font-face{font-family:'CoFo Sans';src:url('/fonts/CoFoSans-Medium.otf') format('opentype');font-weight:500;font-style:normal;font-display:swap}

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:#FDFCF8;font-family:'CoFo Sans',system-ui,sans-serif;color:#211f18;-webkit-font-smoothing:antialiased;overflow-x:hidden}
img{display:block;max-width:100%}
button{font-family:inherit;cursor:pointer}
input,textarea{font-family:inherit}
a{color:#54582f}
a:hover{color:#3c3f21}
input::placeholder,textarea::placeholder{color:rgba(33,31,24,.4)}

@keyframes lumaDrift{0%{transform:scale(1.1) translate(0,0)}50%{transform:scale(1.16) translate(-1.2%,-1%)}100%{transform:scale(1.1) translate(0,0)}}
@keyframes lumaFloatA{0%,100%{transform:rotate(-3deg) translateY(0)}50%{transform:rotate(-3deg) translateY(-10px)}}
@keyframes lumaFloatB{0%,100%{transform:rotate(2.5deg) translateY(0)}50%{transform:rotate(2.5deg) translateY(-8px)}}
@keyframes lumaFloatC{0%,100%{transform:rotate(-1.5deg) translateY(0)}50%{transform:rotate(-1.5deg) translateY(-7px)}}
@keyframes bounce{0%,100%{transform:translateX(-50%) translateY(0)}50%{transform:translateX(-50%) translateY(5px)}}
@media(prefers-reduced-motion:reduce){*{animation:none!important}}

/* NAV */
.nav{position:absolute;top:0;left:0;right:0;display:flex;align-items:center;justify-content:space-between;padding:26px 48px;z-index:20}
.nav-logo{height:66px;width:115px;filter:brightness(0) invert(1);opacity:.97}
.nav-links{display:flex;align-items:center;gap:40px}
.nav-link{font:500 12px/1 'Spline Sans Mono',monospace;letter-spacing:.16em;text-transform:uppercase;color:#fdfcf8;text-decoration:none;padding-bottom:3px;border-bottom:1px solid transparent;transition:border-color .2s}
.nav-link:hover{border-bottom-color:rgba(253,252,248,.7);color:#fdfcf8}
.nav-cart{display:flex;align-items:center;gap:8px;background:none;border:none;color:#fdfcf8;padding:6px 2px;font:500 11px/1 'Spline Sans Mono',monospace;letter-spacing:.06em}
.nav-cart:hover{opacity:.8}

/* HERO */
.hero{position:relative;min-height:100vh;overflow:hidden;background:#20241a}
.hero-bg{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;animation:lumaDrift 48s ease-in-out infinite}
.hero-overlay{position:absolute;inset:0;pointer-events:none;background:linear-gradient(180deg,rgba(20,22,14,.42) 0%,rgba(20,22,14,.05) 26%,rgba(20,22,14,.13) 60%,rgba(20,22,14,.85) 100%)}
.hero-body{position:absolute;left:48px;right:48px;bottom:74px;z-index:10}
.hero-eyebrow{font:500 12px/1 'Spline Sans Mono',monospace;letter-spacing:.34em;text-transform:uppercase;color:rgba(253,252,248,.85);margin-bottom:24px}
.hero-h1{font-family:'Mackinac',serif;font-weight:400;font-size:clamp(48px,6.5vw,80px);line-height:1.02;letter-spacing:-.02em;color:#fdfcf8;max-width:15ch}
.hero-sub{margin:26px 0 0;font:300 18px/1.6 'CoFo Sans';color:rgba(253,252,248,.9);max-width:44ch}
.hero-cta{display:inline-block;margin-top:32px;padding:16px 32px;border-radius:60px;background:#FDFCF8;color:#211f18;font:500 12px/1 'Spline Sans Mono',monospace;letter-spacing:.14em;text-transform:uppercase;text-decoration:none;transition:background .2s}
.hero-cta:hover{background:#efece3;color:#211f18}
.hero-scroll{position:absolute;bottom:28px;left:50%;transform:translateX(-50%);z-index:10;display:flex;flex-direction:column;align-items:center;gap:8px;color:rgba(253,252,248,.7);animation:bounce 2.4s ease-in-out infinite}
.hero-scroll span{font:500 10px/1 'Spline Sans Mono',monospace;letter-spacing:.2em;text-transform:uppercase}

/* PINTURAS */
.pinturas{padding:104px 52px 40px;scroll-margin-top:10px;max-width:1300px;margin:0 auto}
.pinturas-header{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:46px;border-bottom:.5px solid rgba(33,31,24,.2);padding-bottom:24px}
.pinturas-eyebrow{font:500 12px/1 'Spline Sans Mono',monospace;letter-spacing:.3em;text-transform:uppercase;color:#54582f;margin-bottom:18px}
.pinturas-h2{font-family:'Mackinac',serif;font-weight:400;font-size:48px;line-height:1;letter-spacing:-.02em}
.pinturas-ver{font:500 12px/1 'Spline Sans Mono',monospace;letter-spacing:.12em;text-transform:uppercase;color:#211f18;text-decoration:none;border-bottom:1px solid rgba(33,31,24,.4);padding-bottom:6px}
.obras-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:44px 32px}

/* OBRA CARD */
.obra-cell{display:block}
.obra-cell--horizontal{grid-column:span 2}
.obra-frame{position:relative;overflow:hidden;border-radius:4px;background:transparent;transition:transform .5s ease;cursor:pointer}
.obra-frame--vertical{aspect-ratio:106/150}
.obra-frame--horizontal{aspect-ratio:150/106}
.obra-frame--vendida{cursor:default}
.obra-frame:not(.obra-frame--vendida):hover{transform:translateY(-5px)}
.obra-img{width:100%;height:100%;object-fit:contain;transition:filter .5s ease,transform .8s cubic-bezier(.16,1,.3,1)}
.obra-frame:not(.obra-frame--vendida):hover .obra-img{transform:scale(1.04)}
.obra-badge{position:absolute;left:14px;top:14px;z-index:2;display:flex;align-items:center;gap:7px;padding:6px 11px;border-radius:60px;background:rgba(253,252,248,.92);backdrop-filter:blur(3px);transition:opacity .3s ease}
.obra-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
.obra-dot--disp{background:#54582f}
.obra-dot--vend{background:rgba(120,110,90,.55)}
.obra-badge-txt{font:500 10px/1 'Spline Sans Mono',monospace;letter-spacing:.12em;text-transform:uppercase;color:#211f18}
.obra-overlay{position:absolute;inset:0;z-index:3;padding:26px;display:flex;flex-direction:column;justify-content:space-between;background:linear-gradient(180deg,rgba(20,22,14,.28),rgba(20,22,14,.42));opacity:0;visibility:hidden;transition:opacity .4s ease;box-sizing:border-box}
.obra-overlay.active{opacity:1;visibility:visible}
.obra-overlay.active ~ .obra-badge{opacity:0}
.obra-sizes-label{font:500 10px/1 'Spline Sans Mono',monospace;letter-spacing:.24em;text-transform:uppercase;color:rgba(253,252,248,.72);margin-bottom:16px}
.obra-sizes{display:flex;flex-direction:column;gap:9px}
.obra-size-btn{width:100%;text-align:left;padding:11px 14px;border-radius:10px;font:500 12px/1 'Spline Sans Mono',monospace;letter-spacing:.06em;border:1px solid rgba(253,252,248,.4);background:rgba(253,252,248,.12);color:#fdfcf8;backdrop-filter:blur(2px);transition:all .25s ease}
.obra-size-btn:hover{background:rgba(253,252,248,.24);border-color:rgba(253,252,248,.7)}
.obra-size-btn.selected{border-color:#fdfcf8;background:rgba(253,252,248,.96);color:#211f18}
.obra-comprar{align-self:flex-end;margin-top:16px;padding:13px 22px;border-radius:60px;border:none;background:#fdfcf8;color:#211f18;font:500 11px/1 'Spline Sans Mono',monospace;letter-spacing:.14em;text-transform:uppercase;box-shadow:0 6px 18px rgba(10,12,6,.3);transition:transform .2s}
.obra-comprar:hover{transform:scale(1.03)}
.obra-info{padding-top:16px}
.obra-title{font-family:'Mackinac',serif;font-size:21px;font-weight:400}
.obra-desc{font:400 12.5px/1.55 'CoFo Sans';color:rgba(33,31,24,.55);margin-top:5px}
.obra-mat-label{font:500 9px/1 'Spline Sans Mono',monospace;letter-spacing:.18em;text-transform:uppercase;color:rgba(33,31,24,.4);margin-bottom:8px;margin-top:14px}
.obra-mat-btns{display:flex;gap:8px;max-width:220px}
.obra-mat-btn{flex:1;padding:9px 6px;border-radius:8px;font:500 10px/1 'Spline Sans Mono',monospace;letter-spacing:.1em;text-transform:uppercase;border:1px solid rgba(33,31,24,.28);background:transparent;color:rgba(33,31,24,.6);transition:all .2s ease}
.obra-mat-btn.active{border-color:#211f18;background:#211f18;color:#fdfcf8}

/* FONDO AGUA (inspiración + oficio) */
.agua{position:relative;overflow:hidden;scroll-margin-top:10px;background:#171a10}
.agua-bg{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;animation:lumaDrift 64s ease-in-out infinite}
.agua-velo{position:absolute;inset:0;background:linear-gradient(180deg,rgba(16,20,10,.54) 0%,rgba(16,20,10,.4) 26%,rgba(16,20,10,.42) 68%,rgba(16,20,10,.56) 100%);pointer-events:none}
.agua-top{position:absolute;top:-1px;left:0;right:0;height:160px;background:linear-gradient(180deg,#FDFCF8 0%,rgba(253,252,248,.72) 32%,rgba(253,252,248,0) 100%);pointer-events:none;z-index:4}
.agua-bottom{position:absolute;bottom:-1px;left:0;right:0;height:160px;background:linear-gradient(0deg,#FDFCF8 0%,rgba(253,252,248,.72) 32%,rgba(253,252,248,0) 100%);pointer-events:none;z-index:4}
.agua-inner{position:relative;z-index:3}

/* INSPIRACIÓN */
.insp{max-width:1180px;margin:0 auto;padding:132px 52px 44px}
.insp-eyebrow{font:500 12px/1 'Spline Sans Mono',monospace;letter-spacing:.3em;text-transform:uppercase;color:#eef0e2;margin-bottom:8px;text-shadow:0 1px 12px rgba(8,12,4,.65)}
#collage-wrap{position:relative;width:100%;overflow:hidden}
#collage-stage{position:absolute;top:0;left:50%;width:1180px;height:620px;margin-left:-590px;transform-origin:top center}
.polaroid{position:absolute;background:#fff;padding:14px 14px 18px;box-shadow:0 4px 12px rgba(8,10,4,.3),0 26px 60px rgba(8,10,4,.42)}
.polaroid-tape{position:absolute;height:30px;background:rgba(200,205,170,.4);box-shadow:0 2px 4px rgba(8,10,4,.14)}
.polaroid-img{overflow:hidden}
.polaroid-img img{width:100%;height:100%;object-fit:cover}
.insp-quote{position:absolute;left:706px;top:0;width:420px;height:620px;display:flex;align-items:center;justify-content:center;z-index:4}
.insp-quote p{margin:0;text-align:center;font-family:'Mackinac',serif;font-weight:400;font-style:italic;font-size:31px;line-height:1.45;letter-spacing:-.01em;color:#fdfcf8;text-shadow:0 2px 22px rgba(8,12,4,.78),0 0 2px rgba(8,12,4,.5)}

/* EL OFICIO */
.oficio{max-width:1180px;margin:0 auto;padding:40px 52px 150px;scroll-margin-top:10px;display:grid;grid-template-columns:1fr 460px;gap:56px;align-items:center}
.oficio-eyebrow{font:500 12px/1 'Spline Sans Mono',monospace;letter-spacing:.3em;text-transform:uppercase;color:#eef0e2;margin-bottom:22px;text-shadow:0 1px 12px rgba(8,12,4,.65)}
.oficio-h2{font-family:'Mackinac',serif;font-weight:400;font-size:44px;line-height:1.08;letter-spacing:-.02em;color:#fdfcf8;text-shadow:0 2px 22px rgba(8,12,4,.6);margin-bottom:22px}
.oficio-p{font:300 16px/1.7 'CoFo Sans';color:rgba(253,252,248,.95);max-width:46ch;text-shadow:0 1px 16px rgba(8,12,4,.7)}
.oficio-fotos{position:relative;height:400px}

/* GIFTCARDS */
.gc{position:relative;padding:104px 52px;background:#FDFCF8;scroll-margin-top:10px}
.gc-inner{max-width:1180px;margin:0 auto}
.gc-header{text-align:center;margin-bottom:52px}
.gc-eyebrow{font:500 14px/1 'Spline Sans Mono',monospace;letter-spacing:.3em;text-transform:uppercase;color:#54582f;margin-bottom:18px}
.gc-h2{font-family:'Mackinac',serif;font-weight:400;font-size:46px;line-height:1.05;letter-spacing:-.02em;max-width:16ch;margin:0 auto}
.gc-sub{margin:16px auto 0;font:300 16px/1.7 'CoFo Sans';color:rgba(33,31,24,.65);max-width:52ch}
.gc-grid{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:start}
.gc-preview{position:relative;width:100%;aspect-ratio:8/5;border-radius:20px;overflow:hidden;box-shadow:0 6px 16px rgba(30,26,15,.1),0 26px 64px rgba(30,26,15,.2);background-size:cover;background-position:center;transition:background-image .3s}
.gc-preview-overlay{position:absolute;inset:0;background:linear-gradient(135deg,rgba(20,22,14,.5) 0%,rgba(20,22,14,.12) 42%,rgba(20,22,14,.42) 100%)}
.gc-preview-content{position:absolute;inset:0;padding:32px 34px;display:flex;flex-direction:column;justify-content:space-between;color:#fdfcf8}
.gc-preview-top{display:flex;align-items:center;justify-content:space-between}
.gc-logo{height:48px;width:82px;filter:brightness(0) invert(1);opacity:.96}
.gc-tag{font:500 12px/1 'Spline Sans Mono',monospace;letter-spacing:.22em;text-transform:uppercase;opacity:.85}
.gc-monto{font-family:'Mackinac',serif;font-weight:400;font-size:34px;line-height:1;letter-spacing:-.01em;text-shadow:0 1px 12px rgba(8,12,4,.5);text-align:center}
.gc-para-label{font:400 13px/1.4 'Spline Sans Mono',monospace;letter-spacing:.06em;opacity:.9;text-transform:uppercase}
.gc-mensaje-preview{font-family:'Mackinac',serif;font-style:italic;font-size:22px;line-height:1.3;text-shadow:0 1px 12px rgba(8,12,4,.5);max-width:26ch;margin:8px 0 0}
.gc-de-label{margin-top:12px;font:400 12px/1.4 'Spline Sans Mono',monospace;letter-spacing:.06em;opacity:.9;text-transform:uppercase}
.gc-selector-label{display:block;font:500 11px/1 'Spline Sans Mono',monospace;letter-spacing:.2em;text-transform:uppercase;color:#54582f;margin-bottom:10px;margin-top:22px}
.gc-select-wrap{position:relative}
.gc-select{width:100%;appearance:none;-webkit-appearance:none;background:transparent;border:.5px solid rgba(33,31,24,.35);border-radius:12px;padding:14px 44px 14px 16px;font:400 15px 'CoFo Sans';color:#211f18;cursor:pointer;outline:none}
.gc-select-arrow{position:absolute;right:16px;top:50%;transform:translateY(-50%);pointer-events:none}
.gc-amounts{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-top:10px}
.gc-amount-btn{padding:12px 6px;border-radius:10px;font:500 12px/1 'Spline Sans Mono',monospace;letter-spacing:.02em;border:1px solid rgba(33,31,24,.3);background:transparent;color:#211f18;transition:all .2s ease}
.gc-amount-btn.active{border-color:#54582f;background:#54582f;color:#fdfcf8}
.gc-other-wrap{margin-top:12px;position:relative}
.gc-other-prefix{position:absolute;left:16px;top:50%;transform:translateY(-50%);font:400 15px 'CoFo Sans';color:rgba(33,31,24,.5);pointer-events:none}
.gc-other-input{width:100%;box-sizing:border-box;background:transparent;border:.5px solid rgba(33,31,24,.35);border-radius:12px;padding:13px 16px 13px 28px;font:400 15px 'CoFo Sans';color:#211f18;outline:none}
.gc-form{display:flex;flex-direction:column;gap:22px}
.gc-field-label{display:block;font:500 11px/1 'Spline Sans Mono',monospace;letter-spacing:.18em;text-transform:uppercase;color:#54582f;margin-bottom:8px}
.gc-input{width:100%;box-sizing:border-box;background:transparent;border:none;border-bottom:.5px solid rgba(33,31,24,.35);padding:10px 2px;font:400 15px 'CoFo Sans';color:#211f18;outline:none}
.gc-textarea{width:100%;box-sizing:border-box;background:transparent;border:none;border-bottom:.5px solid rgba(33,31,24,.35);padding:10px 2px;font:400 15px/1.5 'CoFo Sans';color:#211f18;outline:none;resize:none}
.gc-btn{align-self:flex-start;margin-top:8px;padding:16px 34px;border-radius:60px;border:none;font:500 12px/1 'Spline Sans Mono',monospace;letter-spacing:.14em;text-transform:uppercase;transition:all .25s ease}
.gc-btn--active{background:#54582f;color:#fdfcf8;cursor:pointer}
.gc-btn--active:hover{background:#3c3f21}
.gc-btn--disabled{background:rgba(33,31,24,.16);color:rgba(33,31,24,.45);cursor:not-allowed}
.gc-hint{margin:2px 0 0;font:300 12.5px/1.6 'CoFo Sans'}

/* CONTACTO */
.contacto{position:relative;padding:100px 52px;background:#F3F0E9;scroll-margin-top:10px}
.contacto-inner{max-width:1180px;margin:0 auto;display:grid;grid-template-columns:1.1fr 1fr;gap:64px}
.contacto-eyebrow{font:500 12px/1 'Spline Sans Mono',monospace;letter-spacing:.3em;text-transform:uppercase;color:#54582f;margin-bottom:18px}
.contacto-h2{font-family:'Mackinac',serif;font-weight:400;font-size:40px;line-height:1.08;letter-spacing:-.02em;margin-bottom:14px}
.contacto-sub{font:300 16px/1.7 'CoFo Sans';color:rgba(33,31,24,.65);max-width:44ch;margin-bottom:32px}
.contacto-form{display:flex;flex-direction:column;gap:20px;max-width:460px}
.contacto-input{background:transparent;border:none;border-bottom:.5px solid rgba(33,31,24,.35);padding:12px 2px;font:400 15px 'CoFo Sans';color:#211f18;outline:none}
.contacto-textarea{background:transparent;border:none;border-bottom:.5px solid rgba(33,31,24,.35);padding:12px 2px;font:400 15px 'CoFo Sans';color:#211f18;outline:none;resize:none}
.contacto-submit{align-self:flex-start;margin-top:12px;padding:16px 36px;border-radius:60px;border:none;background:#211f18;color:#fdfcf8;font:500 12px/1 'Spline Sans Mono',monospace;letter-spacing:.14em;text-transform:uppercase;transition:background .2s}
.contacto-submit:hover{background:#54582f}
.newsletter{border-left:.5px solid rgba(33,31,24,.18);padding-left:60px;display:flex;flex-direction:column;justify-content:flex-start}
.newsletter-eyebrow{font:500 12px/1 'Spline Sans Mono',monospace;letter-spacing:.3em;text-transform:uppercase;color:#54582f;margin-bottom:18px}
.newsletter-h3{font-family:'Mackinac',serif;font-weight:400;font-size:27px;line-height:1.2;margin-bottom:14px}
.newsletter-p{font:300 15px/1.65 'CoFo Sans';color:rgba(33,31,24,.7);max-width:42ch;margin-bottom:26px}
.newsletter-row{display:flex;gap:12px;align-items:center;border-bottom:.5px solid rgba(33,31,24,.35);padding-bottom:8px}
.newsletter-input{flex:1;background:transparent;border:none;padding:8px 2px;font:400 15px 'CoFo Sans';color:#211f18;outline:none}
.newsletter-btn{background:none;border:none;font:500 12px/1 'Spline Sans Mono',monospace;letter-spacing:.12em;text-transform:uppercase;color:#54582f}
.newsletter-btn:hover{color:#3c3f21}

/* FOOTER */
.footer{background:#211f18;color:#f3f0e9;padding:68px 52px 40px}
.footer-inner{max-width:1180px;margin:0 auto}
.footer-top{display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:40px;padding-bottom:46px;border-bottom:.5px solid rgba(243,240,233,.18)}
.footer-logo{height:54px;filter:brightness(0) invert(1);opacity:.95}
.footer-tagline{margin:24px 0 0;font:300 14px/1.7 'CoFo Sans';color:rgba(243,240,233,.65)}
.footer-links{display:flex;gap:76px;flex-wrap:wrap}
.footer-col-label{font:500 11px/1 'Spline Sans Mono',monospace;letter-spacing:.22em;text-transform:uppercase;color:rgba(243,240,233,.5);margin-bottom:16px}
.footer-email{display:block;font:400 15px/1.6 'CoFo Sans';color:#f3f0e9;text-decoration:none}
.footer-email:hover{color:#cdd3ae}
.footer-address{font:300 14px/1.6 'CoFo Sans';color:rgba(243,240,233,.65);margin-top:8px}
.footer-ig{display:inline-flex;align-items:center;gap:10px;color:#f3f0e9;text-decoration:none;font:400 15px 'CoFo Sans'}
.footer-ig:hover{color:#cdd3ae}
.footer-copy{padding-top:24px;font:400 11.5px/1 'CoFo Sans';letter-spacing:.02em;color:rgba(243,240,233,.45)}

/* CART */
.cart-scrim{position:fixed;inset:0;z-index:900;background:rgba(24,22,14,.34);cursor:pointer;opacity:0;visibility:hidden;transition:opacity .45s ease}
.cart-scrim.open{opacity:1;visibility:visible}
.cart-drawer{position:fixed;top:0;right:0;height:100vh;width:360px;max-width:92vw;z-index:1000;transform:translateX(105%);transition:transform .6s cubic-bezier(.16,1,.3,1)}
.cart-drawer.open{transform:translateX(0)}
.cart-inner{height:100%;background:#FDFCF8;border-left:.5px solid rgba(33,31,24,.14);box-shadow:-16px 0 50px rgba(30,26,15,.18);display:flex;flex-direction:column}
.cart-header{display:flex;align-items:center;justify-content:space-between;padding:24px 24px 18px;border-bottom:.5px solid rgba(33,31,24,.14);flex:none}
.cart-title{font-family:'Mackinac',serif;font-size:20px}
.cart-count{color:rgba(33,31,24,.45)}
.cart-close{background:none;border:none;color:#211f18;padding:4px}
.cart-body{flex:1 1 auto;min-height:0;overflow-y:auto;padding:8px 24px}
.cart-empty{padding:48px 6px;text-align:center}
.cart-empty-title{font-family:'Mackinac',serif;font-style:italic;font-size:19px;color:rgba(33,31,24,.6);line-height:1.4}
.cart-empty-sub{margin:14px 0 0;font:300 13px/1.6 'CoFo Sans';color:rgba(33,31,24,.5)}
.cart-item{display:flex;gap:14px;padding:20px 0;border-bottom:.5px solid rgba(33,31,24,.1)}
.cart-item-img{width:66px;height:82px;object-fit:cover;border-radius:2px;flex:none;background:#fff}
.cart-item-title{font-family:'Mackinac',serif;font-size:16px}
.cart-item-detail{font:400 12px/1.5 'CoFo Sans';color:rgba(33,31,24,.55);margin-top:3px}
.cart-item-remove{margin-top:8px;background:none;border:none;padding:0;font:400 11.5px 'CoFo Sans';color:rgba(33,31,24,.5);text-decoration:underline}
.cart-note{font:300 13px/1.6 'CoFo Sans';color:rgba(33,31,24,.55);margin:22px 0 0}
.cart-footer{flex:none;padding:22px 24px;border-top:.5px solid rgba(33,31,24,.14);background:#FDFCF8}
.cart-checkout{width:100%;padding:17px;border:none;border-radius:60px;background:#54582f;color:#fdfcf8;font:500 12px/1 'Spline Sans Mono',monospace;letter-spacing:.14em;text-transform:uppercase}
.cart-checkout:hover{background:#3c3f21}
.cart-pay-label{text-align:center;margin-top:12px;font:400 11px/1 'Spline Sans Mono',monospace;letter-spacing:.06em;color:rgba(33,31,24,.45)}

@media(max-width:900px){
  .nav{padding:20px 24px}
  .nav-links{gap:20px}
  .nav-link{font-size:10px}
  .hero-body{left:24px;right:24px;bottom:48px}
  .hero-h1{font-size:42px}
  .pinturas{padding:72px 24px 40px}
  .obras-grid{grid-template-columns:1fr 1fr;gap:28px 20px}
  .obra-cell--horizontal{grid-column:span 2}
  .insp{padding:80px 24px 44px}
  .oficio{grid-template-columns:1fr;padding:40px 24px 100px;gap:32px}
  .oficio-fotos{height:280px}
  .gc{padding:72px 24px}
  .gc-grid{grid-template-columns:1fr;gap:40px}
  .contacto{padding:72px 24px}
  .contacto-inner{grid-template-columns:1fr;gap:48px}
  .newsletter{border-left:none;padding-left:0;border-top:.5px solid rgba(33,31,24,.18);padding-top:48px}
  .footer{padding:48px 24px 32px}
  .footer-top{flex-direction:column}
}
@media(max-width:600px){
  .nav-links{display:none}
  .obras-grid{grid-template-columns:1fr;gap:28px}
  .obra-cell--horizontal{grid-column:span 1}
  .gc-grid{grid-template-columns:1fr}
  .footer-links{flex-direction:column;gap:32px}
}
</style>
</head>
