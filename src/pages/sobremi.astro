<style is:global>
@font-face{font-family:'Mackinac';src:url('/fonts/Mackinac-Book.otf') format('opentype');font-weight:400;font-style:normal;font-display:swap}
@font-face{font-family:'Mackinac';src:url('/fonts/Mackinac-BookItalic.otf') format('opentype');font-weight:400;font-style:italic;font-display:swap}
@font-face{font-family:'Mackinac';src:url('/fonts/Mackinac-Medium.otf') format('opentype');font-weight:500;font-style:normal;font-display:swap}
@font-face{font-family:'Mackinac';src:url('/fonts/Mackinac-MediumItalic.otf') format('opentype');font-weight:500;font-style:italic;font-display:swap}
@font-face{font-family:'CoFo Sans';src:url('/fonts/CoFoSans-Light.otf') format('opentype');font-weight:300;font-style:normal;font-display:swap}
@font-face{font-family:'CoFo Sans';src:url('/fonts/CoFoSans-Regular.otf') format('opentype');font-weight:400;font-style:normal;font-display:swap}
@font-face{font-family:'CoFo Sans';src:url('/fonts/CoFoSans-Italic.otf') format('opentype');font-weight:400;font-style:italic;font-display:swap}
@font-face{font-family:'CoFo Sans';src:url('/fonts/CoFoSans-Medium.otf') format('opentype');font-weight:500;font-style:normal;font-display:swap}

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;overflow-x:hidden}
body{background:#FDFCF8;font-family:'CoFo Sans',system-ui,sans-serif;color:#211f18;-webkit-font-smoothing:antialiased}
img{display:block;max-width:100%}
a{color:#54582f}
a:hover{color:#3c3f21}

@keyframes lumaDrift{0%{transform:scale(1.08) translate(0,0)}50%{transform:scale(1.15) translate(-1.2%,-1%)}100%{transform:scale(1.08) translate(0,0)}}
@media(prefers-reduced-motion:reduce){*{animation:none!important}}

/* NAV */
.nav{position:absolute;top:0;left:0;right:0;display:flex;align-items:center;justify-content:space-between;padding:26px 48px;z-index:20}
.nav-logo{height:60px;width:104px;filter:brightness(0) invert(1);opacity:.97;object-fit:contain}
.nav-links{display:flex;align-items:center;gap:36px}
.nav-link{font:500 12px/1 'Spline Sans Mono',monospace;letter-spacing:.16em;text-transform:uppercase;color:#fdfcf8;text-decoration:none;padding-bottom:3px;border-bottom:1px solid transparent;transition:border-color .2s}
.nav-link:hover{border-bottom-color:rgba(253,252,248,.7)}
.nav-link--active{border-bottom-color:rgba(253,252,248,.8)}

/* HERO */
.hero{position:relative;min-height:100vh;overflow:hidden;background:#20241a}
.hero-bg{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 32%;animation:lumaDrift 52s ease-in-out infinite}
.hero-overlay{position:absolute;inset:0;background:linear-gradient(180deg,rgba(20,22,14,.5) 0%,rgba(20,22,14,.1) 30%,rgba(20,22,14,.18) 56%,rgba(20,22,14,.64) 100%)}
.hero-body{position:absolute;left:48px;right:48px;bottom:74px;z-index:10}
.hero-eyebrow{font:500 12px/1 'Spline Sans Mono',monospace;letter-spacing:.34em;text-transform:uppercase;color:rgba(253,252,248,.85);margin-bottom:24px}
.hero-h1{font-family:'Mackinac',serif;font-weight:400;font-size:clamp(40px,6vw,78px);line-height:1.02;letter-spacing:-.02em;color:#fdfcf8;max-width:16ch}
.hero-sub{margin:26px 0 0;font:300 18px/1.6 'CoFo Sans';color:rgba(253,252,248,.92);max-width:46ch}

/* MI HISTORIA */
.historia{background:#FDFCF8;padding:112px 48px 100px}
.historia-inner{max-width:940px;margin:0 auto}
.eyebrow{font:500 12px/1 'Spline Sans Mono',monospace;letter-spacing:.3em;text-transform:uppercase;color:#54582f;margin-bottom:20px}
.historia-h2{font-family:'Mackinac',serif;font-weight:400;font-size:clamp(32px,4vw,48px);line-height:1.1;letter-spacing:-.02em;max-width:22ch;margin:0 0 48px}
.historia-grid{display:grid;grid-template-columns:1fr 1fr;gap:52px;align-items:start}
.historia-lead{font-family:'Mackinac',serif;font-weight:400;font-size:21px;line-height:1.65;color:#211f18}
.historia-lead em{font-style:italic}
.historia-cols{display:flex;flex-direction:column;gap:22px}
.historia-p{font:300 16px/1.75 'CoFo Sans';color:rgba(33,31,24,.8)}

/* FILOSOFÍA */
.filosofia{position:relative;overflow:hidden;background:#171a10}
.filosofia-bg{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 38%;animation:lumaDrift 62s ease-in-out infinite}
.filosofia-overlay{position:absolute;inset:0;background:linear-gradient(180deg,rgba(16,20,10,.62) 0%,rgba(16,20,10,.5) 42%,rgba(16,20,10,.72) 100%)}
.filosofia-inner{position:relative;z-index:3;max-width:1080px;margin:0 auto;padding:132px 48px 128px}
.filosofia-eyebrow{font:500 12px/1 'Spline Sans Mono',monospace;letter-spacing:.3em;text-transform:uppercase;color:#cdd3ae;margin-bottom:40px;text-shadow:0 1px 12px rgba(8,12,4,.6)}
.filosofia-quote{font-family:'Mackinac',serif;font-weight:400;font-style:italic;font-size:clamp(32px,5vw,62px);line-height:1.16;letter-spacing:-.025em;color:#fdfcf8;text-shadow:0 2px 26px rgba(8,12,4,.7);max-width:17ch;margin:0 0 64px}
.filosofia-grid{display:grid;grid-template-columns:1.15fr 1fr;gap:56px;align-items:start}
.filosofia-lead{font-family:'Mackinac',serif;font-weight:400;font-size:26px;line-height:1.5;color:#fdfcf8;text-shadow:0 1px 16px rgba(8,12,4,.6);margin:0 0 22px}
.filosofia-lead em{font-style:italic;color:#cdd3ae}
.filosofia-texto{column-count:2;column-gap:34px;font:300 15px/1.8 'CoFo Sans';color:rgba(253,252,248,.9);text-shadow:0 1px 14px rgba(8,12,4,.5)}
.filosofia-material{border-top:.5px solid rgba(253,252,248,.35);padding-top:24px}
.filosofia-mat-label{font:500 12px/1 'Spline Sans Mono',monospace;letter-spacing:.24em;text-transform:uppercase;color:#cdd3ae;margin-bottom:18px}
.filosofia-mat-p{font-family:'Mackinac',serif;font-weight:400;font-size:19px;line-height:2;color:rgba(253,252,248,.92);text-shadow:0 1px 14px rgba(8,12,4,.5)}
.filosofia-mat-p em{font-style:italic}

/* CTA OBRAS */
.obras{background:#FDFCF8;padding:104px 48px 108px;text-align:center}
.obras-intro{max-width:760px;margin:0 auto 52px}
.obras-h2{font-family:'Mackinac',serif;font-weight:400;font-size:clamp(30px,3.5vw,44px);line-height:1.08;letter-spacing:-.02em;margin:0 0 16px}
.obras-sub{font:300 16px/1.7 'CoFo Sans';color:rgba(33,31,24,.65);max-width:50ch;margin:0 auto}
.obras-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:28px;max-width:760px;margin:0 auto 52px;align-items:end}
.obras-thumb{aspect-ratio:106/150;overflow:hidden;border-radius:4px;background:#f0ede6}
.obras-thumb img{width:100%;height:100%;object-fit:contain}
.obras-btn{display:inline-block;padding:16px 34px;border-radius:60px;background:#211f18;color:#fdfcf8;font:500 12px/1 'Spline Sans Mono',monospace;letter-spacing:.14em;text-transform:uppercase;text-decoration:none;transition:background .2s}
.obras-btn:hover{background:#54582f;color:#fdfcf8}

/* FOOTER */
.footer{background:#211f18;color:#f3f0e9;padding:64px 48px 38px}
.footer-inner{max-width:1000px;margin:0 auto}
.footer-top{display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:36px;padding-bottom:42px;border-bottom:.5px solid rgba(243,240,233,.18)}
.footer-logo{height:52px;filter:brightness(0) invert(1);opacity:.95}
.footer-tagline{margin:22px 0 0;font:300 14px/1.7 'CoFo Sans';color:rgba(243,240,233,.65)}
.footer-ig-label{font:500 11px/1 'Spline Sans Mono',monospace;letter-spacing:.22em;text-transform:uppercase;color:rgba(243,240,233,.5);margin-bottom:14px}
.footer-ig{display:inline-flex;align-items:center;gap:10px;color:#f3f0e9;text-decoration:none;font:400 15px 'CoFo Sans'}
.footer-ig:hover{color:#cdd3ae}
.footer-copy{padding-top:22px;font:400 11.5px/1 'CoFo Sans';color:rgba(243,240,233,.45)}

/* RESPONSIVE */
@media(max-width:900px){
  .nav{padding:20px 24px}
  .nav-links{gap:20px}
  .nav-link{font-size:10px}
  .hero-body{left:24px;right:24px;bottom:48px}
  .historia{padding:72px 24px 72px}
  .historia-grid{grid-template-columns:1fr}
  .filosofia-inner{padding:88px 24px 88px}
  .filosofia-grid{grid-template-columns:1fr;gap:40px}
  .filosofia-texto{column-count:1}
  .obras{padding:72px 24px 80px}
  .footer{padding:48px 24px 32px}
  .footer-top{flex-direction:column}
}
@media(max-width:600px){
  .nav-links{display:none}
  .nav-logo{height:50px;width:87px}
  .hero-h1{font-size:34px}
  .hero-sub{font-size:15px;max-width:none}
  .historia-lead{font-size:18px}
  .filosofia-quote{font-size:28px;margin-bottom:40px}
  .filosofia-lead{font-size:20px}
  .obras-grid{grid-template-columns:1fr;max-width:260px}
}
@media(max-width:400px){
  .hero-h1{font-size:28px}
  .hero-sub{font-size:14px}
}
</style>
</head>
<body>

<!-- HERO -->
<article>
<section class="hero" id="top" aria-label="Presentación — Sobre Luma">
  <img
    class="hero-bg"
    src="/img/sobremi-hero.jpg"
    alt="Figura de blanco en movimiento entre flores de un campo del sur de Chile — arte patagónico Luma"
    fetchpriority="high"
    decoding="async"
  />
  <div class="hero-overlay" aria-hidden="true"></div>
  <nav class="nav" aria-label="Navegación principal">
    <a href="/" aria-label="Ir al inicio — Luma Arte">
      <img class="nav-logo" src="/img/luma-logo.png" alt="Luma Arte" />
    </a>
    <div class="nav-links">
      <a class="nav-link" href="/#pinturas">Pinturas</a>
      <a class="nav-link nav-link--active" href="/sobremi" aria-current="page">Sobre mí</a>
      <a class="nav-link" href="/#blog">Blog</a>
      <a class="nav-link" href="/#giftcards">Giftcard</a>
      <a class="nav-link" href="/#contacto">Contacto</a>
    </div>
  </nav>
  <div class="hero-body">
    <p class="hero-eyebrow">Sobre Luma</p>
    <h1 class="hero-h1">La naturaleza salvaje, hecha <em>arte</em>.</h1>
    <p class="hero-sub">Pintura original nacida en la Patagonia chilena — un lenguaje intuitivo entre acuarela, acrílicos, pastel al óleo e hilo.</p>
  </div>
</section>

<!-- MI HISTORIA -->
<section class="historia" aria-labelledby="historia-titulo">
  <div class="historia-inner">
    <p class="eyebrow">Mi historia</p>
    <h2 class="historia-h2" id="historia-titulo">El arte llegó como una forma de <em>respirar</em>.</h2>
    <div class="historia-grid">
      <p class="historia-lead">Pinto desde que tengo <em>memoria</em>. El arte llegó a mí casi como una forma de respirar: el canto, la representación de personajes, la interpretación de la realidad a través de la pintura. Nunca fue una decisión — siempre fue un lenguaje <em>intuitivo</em>, algo que ya sabía hacer antes de saber nombrarlo.</p>
      <div class="historia-cols">
        <p class="historia-p">Cuando llegó la maternidad, esa necesidad de crear se volvió más profunda, casi urgente. Cada pieza es hoy un espacio de sanación: un lugar donde proceso lo que no siempre tiene palabras.</p>
        <p class="historia-p">Después de años en la ciudad, me vine a vivir al Sur, a la Patagonia chilena. Y aquí, entre Puerto Varas y Frutillar, encontré mi verdadera fuente de inspiración: en el vuelo sutil de las aves, en la brisa moviendo las hojas, en el Lago Llanquihue que a veces es mar y a veces espejo.</p>
      </div>
    </div>
  </div>
</section>

<!-- FILOSOFÍA -->
<section class="filosofia" aria-labelledby="filosofia-titulo">
  <img
    class="filosofia-bg"
    src="/img/sobremi-filosofia.jpg"
    alt="Figura de blanco en movimiento entre rayos de luz y telas — la naturaleza salvaje que inspira a Luma"
    decoding="async"
  />
  <div class="filosofia-overlay" aria-hidden="true"></div>
  <div class="filosofia-inner">
    <p class="filosofia-eyebrow" id="filosofia-titulo">La naturaleza salvaje</p>
    <blockquote class="filosofia-quote">
      <p>Creo en la conexión intuitiva y salvaje que habita en las mujeres.</p>
    </blockquote>
    <div class="filosofia-grid">
      <div>
        <p class="filosofia-lead">Me inspiran los procesos terapéuticos que surgen al pisar <em>descalza</em> la naturaleza, al observar el dolor con valentía en lugar de huir de él.</p>
        <p class="filosofia-texto">Eso son mis obras: un reflejo de la <span style="font-family:'Mackinac',serif;font-style:italic;font-size:17px;color:#fff">naturaleza salvaje</span> que he ido descubriendo, dentro y fuera de mí. Cada pieza nace del movimiento del Sur — la bruma sobre el lago, el viento entre las hojas, la luz que se filtra al amanecer — y se detiene en el papel como un instante que respira.</p>
      </div>
      <div class="filosofia-material">
        <p class="filosofia-mat-label">El material de mis obras</p>
        <p class="filosofia-mat-p">Cada obra es técnica mixta —acuarela, pastel al óleo, acrílicos e hilo sobre papel de algodón o canvas— enmarcada en madera nativa reciclada: mañío, laurel, coihue y roble.<br /><br /><em>Creemos en lo sostenible como forma de crear.</em></p>
      </div>
    </div>
  </div>
</section>

<!-- CTA OBRAS -->
<section class="obras" aria-label="Ver las pinturas originales de Luma">
  <div class="obras-intro">
    <p class="eyebrow">Las obras</p>
    <h2 class="obras-h2">Lleva un pedazo <em>del Sur</em> a tu espacio</h2>
    <p class="obras-sub">Cada pintura es original e irrepetible — arte con alma para tu hogar, o como regalo original para bodas y empresas.</p>
  </div>
  <div class="obras-grid" role="list" aria-label="Muestra de pinturas originales">
    <div class="obras-thumb" role="listitem">
      <img src="/img/obra1_white.png" alt="Dúo Lilium y Volcanes I — pintura original de Luma, técnica mixta, sur de Chile" loading="lazy" decoding="async" />
    </div>
    <div class="obras-thumb" role="listitem">
      <img src="/img/obra2_white.png" alt="Dúo Lilium y Volcanes II — pintura original de Luma, arte patagónico" loading="lazy" decoding="async" />
    </div>
    <div class="obras-thumb" role="listitem">
      <img src="/img/obra4_white.png" alt="Mujer Hortensia — obra de arte original, acuarela y pastel al óleo" loading="lazy" decoding="async" />
    </div>
  </div>
  <a class="obras-btn" href="/#pinturas">Ver todas las pinturas →</a>
</section>
</article>

<!-- FOOTER -->
<footer class="footer" aria-label="Pie de página">
  <div class="footer-inner">
    <div class="footer-top">
      <div>
        <img class="footer-logo" src="/img/luma-logo.png" alt="Luma Arte — arte patagónico original" />
        <p class="footer-tagline">Arte original inspirado en la naturaleza del sur de Chile.<br />Puerto Varas, Patagonia.</p>
      </div>
      <div>
        <p class="footer-ig-label">Síguenos</p>
        <a class="footer-ig" href="https://www.instagram.com/lumaartechile" target="_blank" rel="noopener noreferrer" aria-label="Seguir a Luma Arte en Instagram">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5.5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
          @lumaartechile
        </a>
      </div>
    </div>
    <p class="footer-copy">© 2026 Luma Producciones · Arte patagónico original.</p>
  </div>
</footer>

</body>
